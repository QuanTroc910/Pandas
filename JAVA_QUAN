Sử dụng HashMap<String, ArrayList<String>> để nhóm (không dùng groupingBy của Stream API).
In các lớp theo thứ tự alphabet tăng dần (đưa key sang TreeMap hoặc sort danh sách key).
Trong mỗi lớp, in danh sách tên theo thứ tự xuất hiện trong input (không sort tên).
import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        HashMap<String, ArrayList<String>> groups = new HashMap<>();
       
        // 1. Duyệt qua N sinh viên để phân nhóm vào HashMap
        for (int i = 0; i < n; i++) {
            String lop = sc.next();
            String ten = sc.next();
           
            // Nếu Key 'lop' chưa tồn tại, tự động khởi tạo ArrayList mới,
            // sau đó thêm 'ten' vào danh sách. Duy trì đúng thứ tự xuất hiện.
            groups.computeIfAbsent(lop, k -> new ArrayList<>()).add(ten);
        }


        // 2. Chuyển toàn bộ dữ liệu từ HashMap sang TreeMap để tự động sắp xếp tên lớp theo alphabet
        TreeMap<String, ArrayList<String>> sortedGroups = new TreeMap<>(groups);


        // 3. Duyệt TreeMap và in kết quả đầu ra theo đúng định dạng yêu cầu
        for (Map.Entry<String, ArrayList<String>> entry : sortedGroups.entrySet()) {
            String lop = entry.getKey();
            ArrayList<String> dsTen = entry.getValue();
           
            // In ra tên lớp theo cấu trúc "<lop>:"
