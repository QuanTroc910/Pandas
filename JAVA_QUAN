using namespace std;


// Hàm tính giai thừa của n và trả về dưới dạng chuỗi (String)
string tinhGiaiThua(int n) {
    vector<int> result;
    result.push_back(1); // Ban đầu bằng 1


    for (int i = 2; i <= n; i++) {
        int carry = 0;
        for (size_t j = 0; j < result.size(); j++) {
            long long current = (long long)result[j] * i + carry;
            result[j] = current % 10;
            carry = current / 10;
        }
        while (carry > 0) {
            result.push_back(carry % 10);
            carry /= 10;
        }
    }


    // Chuyển mảng số ngược lại thành chuỗi ký tự
    string factStr = "";
    for (int i = result.size() - 1; i >= 0; i--) {
        factStr += to_string(result[i]);
    }
    return factStr;
}


void solve() {
    int n;
    cin >> n;
    string s;
    cin >> s;


    // 1. Tính toán giá trị thực tế chính xác của n!
    string stringGoc = tinhGiaiThua(n);


    // 2. Tìm vị trí xuất hiện của đoạn chữ cái trong chuỗi s
    int startIdx = -1;
    int length = 0;
   
    for (size_t i = 0; i < s.length(); i++) {
        if (isalpha(s[i])) { // Nếu là ký tự chữ (a-z, A-Z)
            if (startIdx == -1) {
                startIdx = i;
            }
            length++;
        }
    }


