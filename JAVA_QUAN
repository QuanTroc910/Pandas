Hãy viết chương trình thực hiện:
a. Sử dụng DataOutputStream để ghi 4 số nguyên được nhập từ bàn phím vào file int.txt b. Sử dụng DataInputStream để đọc lại 4 số nguyên trong file và tính tổng của 4 số c. In ra màn hình kết quả theo định dạng
Bài  làm:
import java.io.DataInputStream;
import java.io.DataOutputStream;
import java.io.FileInputStream;
import java.io.FileOutputStream;
import java.io.IOException;
import java.util.Scanner;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Mảng chứa 4 số nguyên nhập từ bàn phím
        int[] numbers = new int[4];
        for (int i = 0; i < 4; i++) {
            if (sc.hasNextInt()) {
                numbers[i] = sc.nextInt();
            }
        }
        sc.close();


        String fileName = "int.txt";


        // a. Ghi các số vào file bằng DataOutputStream (Sử dụng try-with-resources để tự đóng luồng)
        try (DataOutputStream dos = new DataOutputStream(new FileOutputStream(fileName))) {
            for (int num : numbers) {
                dos.writeInt(num); // Ghi số nguyên dạng nhị phân 4-byte xuống file
            }
        } catch (IOException e) {
            e.printStackTrace();
        }


        int sum = 0;


        // b. Đọc các số từ file bằng DataInputStream và cộng dồn vào biến sum
        try (DataInputStream dis = new DataInputStream(new FileInputStream(fileName))) {
            for (int i = 0; i < 4; i++) {
                sum += dis.readInt(); // Đọc ngược lại cấu trúc 4-byte nhị phân thành số int
            }
        } catch (IOException e) {
            e.printStackTrace();
        }


        // c. Xuất kết quả theo đúng định dạng đầu ra của hệ thống
        System.out.println("Tổng của các số nguyên là: " + sum);
    }
}
