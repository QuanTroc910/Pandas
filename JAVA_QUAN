Hãy xử lý dữ liệu bằng Java Streams, trong đó sử dụng Predicate, Function, Comparator và Consumer:
import java.util.*;
import java.util.function.*;
import java.util.stream.*;


class Customer {
    String name;
    int times;


    Customer(String name, int times) {
        this.name = name;
        this.times = times;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);


        if (!sc.hasNextLine()) return;
        int N = Integer.parseInt(sc.nextLine().trim());
        List<Customer> list = new ArrayList<>();


        for (int i = 0; i < N; i++) {
            String[] p = sc.nextLine().split(" ");
            list.add(new Customer(p[0], Integer.parseInt(p[1])));
        }


        // 1. Predicate: lọc các khách hàng có số lần sử dụng dịch vụ >= 3
        Predicate<Customer> serviceFilter = c -> c.times >= 3;


        // 2. Function: chuyển đổi từ Customer sang mảng Object[] chứa: [tên (String), số lần (Integer), phí (Double)]
        // Công thức tính phí: số_lần * 15.000
        Function<Customer, Object[]> feeCalculator = c -> new Object[]{ c.name, c.times, (double) c.times * 15000 };


        // 3. Comparator: sắp xếp danh sách mảng Object[] theo tiêu chí phí (ở chỉ số index số 2) giảm dần
        Comparator<Object[]> feeDescending = (obj1, obj2) -> Double.compare((double) obj2[2], (double) obj1[2]);


        // 4. Consumer: thực thi in ra màn hình theo cấu trúc yêu cầu, phí hiển thị 2 chữ số thập phân
        Consumer<Object[]> printResult = obj -> System.out.printf(Locale.US, "%s %d %.2f\n", obj[0], obj[1], obj[2]);


        // --- Áp dụng tất cả các đối tượng chức năng trên vào cấu trúc Stream pipeline ---
        list.stream()
            .filter(serviceFilter)  // Bước 1: Lọc dữ liệu bằng Predicate
            .map(feeCalculator)     // Bước 2: Biến đổi dữ liệu bằng Function
            .sorted(feeDescending)  // Bước 3: Sắp xếp dữ liệu bằng Comparator
            .forEach(printResult);  // Bước 4: In dữ liệu bằng Consumer


        sc.close();
    }
}
