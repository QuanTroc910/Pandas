A ∪ B (hợp)
A ∩ B (giao)
A \ B (hiệu A trừ B — phần tử có trong A nhưng không có trong B)
Mỗi tập in trên một dòng theo thứ tự tăng dần. Dùng HashSet và TreeSet.
import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);


        // 1. Nhập tập hợp A và tự động loại trùng, sắp xếp bằng TreeSet
        if (!sc.hasNextInt()) return;
        int nA = sc.nextInt();
        TreeSet<Integer> setA = new TreeSet<>();
        for (int i = 0; i < nA; i++) {
            setA.add(sc.nextInt());
        }


        // 2. Nhập tập hợp B tương tự
        if (!sc.hasNextInt()) return;
        int nB = sc.nextInt();
        TreeSet<Integer> setB = new TreeSet<>();
        for (int i = 0; i < nB; i++) {
            setB.add(sc.nextInt());
        }


        // 3. Tính Phép Hợp (UNION): Gộp toàn bộ B vào bản sao của A
        TreeSet<Integer> unionSet = new TreeSet<>(setA);
        unionSet.addAll(setB);


        // 4. Tính Phép Giao (INTERSECT): Chỉ giữ lại phần tử chung với B
        TreeSet<Integer> intersectSet = new TreeSet<>(setA);
        intersectSet.retainAll(setB);


        // 5. Tính Phép Hiệu (DIFF): Xóa toàn bộ phần tử thuộc B ra khỏi A
        TreeSet<Integer> diffSet = new TreeSet<>(setA);
        diffSet.removeAll(setB);


        // 6. In kết quả phép Hợp
        System.out.print("UNION:");
        for (int num : unionSet) {
            System.out.print(" " + num);
        }
        System.out.println();


        // 7. In kết quả phép Giao
        System.out.print("INTERSECT:");
        for (int num : intersectSet) {
            System.out.print(" " + num);
        }
        System.out.println();


        // 8. In kết quả phép Hiệu
        System.out.print("DIFF:");
        for (int num : diffSet) {
            System.out.print(" " + num);
        }
        System.out.println();


        sc.close();
    }
}
