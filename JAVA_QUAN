Cho mảng N số nguyên. Hãy chia mảng cho K luồng, mỗi luồng tính min và max cục bộ trên phần mình phụ trách. Sau khi tất cả luồng kết thúc, tổng hợp ra min và max toàn cục. 
import java.util.*;


// Định nghĩa lớp MinMaxThread kế thừa từ Thread
class MinMaxThread extends Thread {
    int[] arr;
    int from;
    int to;
    int localMin = Integer.MAX_VALUE;
    int localMax = Integer.MIN_VALUE;


    // Constructor nạp dữ liệu phân đoạn mảng cho luồng phụ trách
    public MinMaxThread(int[] arr, int from, int to) {
        this.arr = arr;
        this.from = from;
        this.to = to;
    }


    // Logic tìm Min và Max cục bộ chạy song song
    @Override
    public void run() {
        for (int i = from; i < to; i++) {
            if (arr[i] < localMin) {
                localMin = arr[i];
            }
            if (arr[i] > localMax) {
                localMax = arr[i];
            }
        }
    }
}


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào tránh lỗi hệ thống OJ khi quét file rỗng
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }
        int k = sc.nextInt();


        // Tạo mảng quản lý K luồng xử lý song song
        MinMaxThread[] threads = new MinMaxThread[k];


        // Thuật toán chia đoạn mảng tối ưu cho K luồng (xử lý tốt trường hợp n không chia hết cho k)
        int baseSize = n / k;
        int remainder = n % k;


        int currentStart = 0;
        for (int i = 0; i < k; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);


            // Khởi tạo luồng và kích hoạt chạy song song bằng lệnh start()
            threads[i] = new MinMaxThread(arr, currentStart, currentEnd);
            threads[i].start();


            currentStart = currentEnd;
        }


        // Khởi tạo biến lưu kết quả toàn cục giống như logic của luồng cục bộ
        int globalMin = Integer.MAX_VALUE;
        int globalMax = Integer.MIN_VALUE;


        // Chờ các luồng hoàn thành và tiến hành thu hoạch, tổng hợp kết quả toàn cục
        for (int i = 0; i < k; i++) {
            threads[i].join(); // Đợi luồng i chạy xong hoàn toàn
           
            // So sánh kết quả cục bộ của luồng i với kết quả toàn cục
            if (threads[i].localMin < globalMin) {
                globalMin = threads[i].localMin;
            }
            if (threads[i].localMax > globalMax) {
                globalMax = threads[i].localMax;
            }
        }


        // In ra kết quả theo đúng định dạng yêu cầu: <min> <max>
        System.out.println(globalMin + " " + globalMax);


        sc.close();
    }
}
