        this.owner = owner;
        this.kwh = kwh;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextLine()) return;
        int N = Integer.parseInt(sc.nextLine().trim());


        List<Home> list = new ArrayList<>();
        for (int i = 0; i < N; i++) {
            String[] p = sc.nextLine().split(" ");
            list.add(new Home(p[0], Double.parseDouble(p[1])));
        }


        // 1. Khai báo Predicate: lọc những hộ có mức tiêu thụ >= 50 kWh
        Predicate<Home> kwhFilter = h -> h.kwh >= 50.0;


        // 2. Khai báo Function: quy đổi Home -> Object[] chứa [Tên (String), kWh (Double), Tiền điện (Double)]
        // Công thức: tiền = kWh * 3500
        Function<Home, Object[]> billCalculator = h -> new Object[]{ h.owner, h.kwh, h.kwh * 3500.0 };


        // 3. Khai báo Comparator: sắp xếp theo trường tiền điện (chỉ số index = 2 trong mảng Object[]) giảm dần
        // Đảo thứ tự truyền obj2 lên trước obj1 để lấy giá trị giảm dần
        String formatSpec = "%.2f";
        Comparator<Object[]> billDescending = (obj1, obj2) -> Double.compare((double) obj2[2], (double) obj1[2]);


        // 4. Khai báo Consumer: in danh sách ra màn hình theo cấu trúc yêu cầu
        // Cả kWh và Tiền điện đều hiển thị ở định dạng 2 chữ số thập phân
        Consumer<Object[]> printBill = obj -> System.out.printf(Locale.US, "%s " + formatSpec + " " + formatSpec + "\n", obj[0], obj[1], obj[2]);


        // --- Sử dụng các đối tượng trên xuyên suốt Stream pipeline để xử lý dữ liệu ---
        list.stream()
            .filter(kwhFilter)       // Bước 1: Lọc dữ liệu bằng Predicate
            .map(billCalculator)     // Bước 2: Biến đổi cấu trúc bằng Function
            .sorted(billDescending)  // Bước 3: Sắp xếp dữ liệu bằng Comparator
            .forEach(printBill);     // Bước 4: Thực thi hành động đầu ra bằng Consumer


        sc.close();
    }
}
Cho một chuỗi gồm các ký tự chữ thường a–z. Hãy in ra các ký tự theo thứ tự alphabet kèm số lần xuất hiện của chúng.
Dùng TreeMap<Character, Integer> để vừa đếm vừa sắp xếp tự nhiên.
import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNext()) return;
        String s = sc.next();
       
        // Khởi tạo TreeMap để lưu trữ: Key là Ký tự, Value là Số lần xuất hiện
        TreeMap<Character, Integer> tm = new TreeMap<>();
       
        // 1. Duyệt qua từng ký tự trong chuỗi để tiến hành đếm tần suất
        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
           
            // Nếu ký tự đã tồn tại thì tăng số đếm lên 1, nếu chưa có thì mặc định là 0 rồi cộng 1
            tm.put(c, tm.getOrDefault(c, 0) + 1);
        }


        // 2. Duyệt qua TreeMap (lúc này các ký tự đã được tự động sắp xếp theo alphabet) để in kết quả
        for (Map.Entry<Character, Integer> entry : tm.entrySet()) {
            System.out.println(entry.getKey() + " " + entry.getValue());
        }
       
        sc.close();
    }
}
