import java.util.*;


// Định nghĩa lớp ReverseThread kế thừa từ Thread
class ReverseThread extends Thread {
    String[] arr;
    int from, to;


    // Constructor nạp dữ liệu phân đoạn mảng cho luồng phụ trách
    public ReverseThread(String[] arr, int from, int to) {
