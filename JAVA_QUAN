import java.util.*;


public class Main {
    // Khai báo các mảng song song và biến dùng chung dạng static
    static String[] ids;
    static String[] names;
    static double[] balances;
   
    static int totalAccounts = 0;
    static double totalBalance = 0;


    // Hàm phụ tìm chỉ số (index) của tài khoản dựa vào accountId
    // Trả về -1 nếu không tìm thấy
    static int findIndex(String accountId) {
        for (int i = 0; i < totalAccounts; i++) {
            if (ids[i].equals(accountId)) {
                return i;
            }
        }
        return -1;
    }


    // Hàm nạp tiền vào tài khoản
    static void deposit(String accountId, double amount) {
        int idx = findIndex(accountId);
        if (idx != -1) {
            balances[idx] += amount;
            totalBalance += amount; // Cập nhật tổng số dư toàn hệ thống
        }
    }


    // Hàm rút tiền từ tài khoản (chỉ rút nếu đủ số dư)
    static void withdraw(String accountId, double amount) {
        int idx = findIndex(accountId);
        if (idx != -1 && balances[idx] >= amount) {
            balances[idx] -= amount;
            totalBalance -= amount; // Cập nhật tổng số dư toàn hệ thống
        }
    }


    // Hàm chuyển tiền giữa hai tài khoản
    static void transfer(String fromId, String toId, double amount) {
        int fromIdx = findIndex(fromId);
        int toIdx = findIndex(toId);
       
        // Chỉ thực hiện chuyển nếu cả 2 tài khoản tồn tại và tài khoản nguồn đủ tiền
        if (fromIdx != -1 && toIdx != -1 && balances[fromIdx] >= amount) {
            balances[fromIdx] -= amount;
            balances[toIdx] += amount;
            // totalBalance không đổi vì đây là giao dịch nội bộ
        }
    }


    // Hàm tính số dư trung bình của hệ thống
    static double getAverageBalance() {
        if (totalAccounts == 0) return 0.0;
        return totalBalance / totalAccounts;
    }


    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        // Cấp phát kích thước cho các mảng song song
        ids = new String[n];
        names = new String[n];
        balances = new double[n];
       
        // Đọc dữ liệu n tài khoản ban đầu
        for (int i = 0; i < n; i++) {
            ids[i] = sc.next();
            names[i] = sc.next();
            balances[i] = sc.nextDouble();
           
            // Cập nhật các biến dùng chung toàn hệ thống
            totalAccounts++;
            totalBalance += balances[i];
        }
       
        if (!sc.hasNextInt()) {
            // Nếu không có thao tác nào tiếp theo, in kết quả hiện tại và dừng
            System.out.printf("%.2f\n", getAverageBalance());
            sc.close();
            return;
        }
       
        int m = sc.nextInt();
       
        // Xử lý m thao tác giao dịch tuần tự
        for (int i = 0; i < m; i++) {
            String command = sc.next();
           
            if (command.equals("DEPOSIT")) {
                String accountId = sc.next();
                double amount = sc.nextDouble();
                deposit(accountId, amount);
               
            } else if (command.equals("WITHDRAW")) {
                String accountId = sc.next();
                double amount = sc.nextDouble();
                withdraw(accountId, amount);
               
            } else if (command.equals("TRANSFER")) {
                String fromId = sc.next();
                String toId = sc.next();
                double amount = sc.nextDouble();
                transfer(fromId, toId, amount);
            }
        }
       
        // In ra số dư trung bình cuối cùng làm tròn 2 chữ số thập phân
        System.out.printf("%.2f\n", getAverageBalance());
       
        sc.close();
    }
}
