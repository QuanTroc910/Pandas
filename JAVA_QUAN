Mở ints.bin bằng DataInputStream, đọc từng số bằng readInt cho đến hết file (EOFException), tìm min và max.
import java.io.*;
import java.util.*;


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
        String filePath = "ints.bin";


        // Chốt chặn kiểm tra an toàn đầu vào rỗng
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();


        // 1. Ghi N số nguyên vào file ints.bin bằng DataOutputStream
        try (DataOutputStream dos = new DataOutputStream(new FileOutputStream(filePath))) {
            for (int i = 0; i < n; i++) {
                dos.writeInt(sc.nextInt());
            }
            dos.flush(); // Đẩy toàn bộ dữ liệu từ bộ đệm xuống đĩa cứng
        }


        // Khởi tạo giá trị biên để chuẩn bị tìm min, max
        int min = Integer.MAX_VALUE;
        int max = Integer.MIN_VALUE;


        // 2. Mở ints.bin bằng DataInputStream, đọc cho đến khi gặp ngoại lệ EOFException
        try (DataInputStream dis = new DataInputStream(new FileInputStream(filePath))) {
            while (true) {
                int num = dis.readInt(); // Đọc 4 bytes nhị phân khôi phục thành số nguyên ban đầu
               
                // Cập nhật min và max liên tục qua từng số đọc được
                if (num < min) min = num;
                if (num > max) max = num;
            }
        } catch (EOFException e) {
            // Khối catch này bắt ngoại lệ hết file (EOF), là điểm dừng hợp pháp của vòng lặp duyệt dữ liệu
        }


        // 3. In kết quả 2 dòng ra màn hình theo đúng mẫu yêu cầu của đề bài
        System.out.println("min: " + min);
        System.out.println("max: " + max);


        sc.close();
    }
}


