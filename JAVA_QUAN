import java.io.*;
import java.util.Scanner;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNextLine()) return;
        String data = sc.nextLine();
        String filePath = "input.txt";


        // 1. Ghi chuỗi vừa nhập vào file input.txt bằng FileWriter
        try (FileWriter writer = new FileWriter(filePath)) {
            writer.write(data);
            writer.flush(); // Đảm bảo dữ liệu được đẩy hoàn toàn xuống đĩa cứng
        } catch (IOException e) {
            e.printStackTrace();
        }


        // Biến lưu trữ chuỗi đọc ngược lại từ file
        String fileContent = "";


        // 2. Đọc lại nội dung từ file input.txt bằng BufferedReader
        try (BufferedReader reader = new BufferedReader(new FileReader(filePath))) {
            fileContent = reader.readLine();
        } catch (IOException e) {
            e.printStackTrace();
        }


        // Khởi tạo các biến đếm cho 3 nhóm ký tự
