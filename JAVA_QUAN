Viết chương trình:
Đọc nhiều dòng từ bàn phím, ghi nguyên vào file in.txt bằng FileWriter.
Đọc lại in.txt bằng BufferedReader. Với mỗi dòng, thêm tiền tố " " (2 khoảng trắng) phía trước.
Ghi kết quả ra out.txt bằng BufferedWriter.
Đọc lại out.txt và in ra stdout.
import java.io.*;
import java.util.*;


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
        String inFile = "in.txt";
        String outFile = "out.txt";


        // 1. Đọc nhiều dòng từ bàn phím cho đến khi hết dữ liệu (EOF) và ghi vào in.txt
        try (FileWriter fw = new FileWriter(inFile)) {
            while (sc.hasNextLine()) {
                String line = sc.nextLine();
                fw.write(line);
                fw.write("\n");
            }
            fw.flush();
        }


        // 2. Đọc lại in.txt bằng BufferedReader, thêm 2 khoảng trắng đầu dòng, ghi ra out.txt bằng BufferedWriter
        try (
            BufferedReader br = new BufferedReader(new FileReader(inFile));
            BufferedWriter bw = new BufferedWriter(new FileWriter(outFile))
        ) {
            String line;
            while ((line = br.readLine()) != null) {
                // Thêm tiền tố 2 khoảng trắng phía trước bất kể nội dung dòng là gì
                bw.write("  " + line);
                bw.newLine(); // Xuống dòng cho file out.txt
            }
            bw.flush();
        }


        // 3. Đọc lại file out.txt bằng BufferedReader và in trực tiếp ra màn hình (stdout)
        try (BufferedReader brOut = new BufferedReader(new FileReader(outFile))) {
            String line;
            while ((line = brOut.readLine()) != null) {
                System.out.println(line);
            }
        }


        sc.close();
    }
}
