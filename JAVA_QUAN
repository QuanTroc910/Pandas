Xây dựng lớp Vec2 biểu diễn vector 2 chiều.
Lớp Vec2 gồm double x, y.
Phương thức:
Vec2 add(Vec2 o) — cộng vector.
Vec2 sub(Vec2 o) — trừ vector.
double dot(Vec2 o) — tích vô hướng = x*o.x + y*o.y.
double length() — độ dài = sqrt(x*x + y*y).
String toString() trả (x, y) với mỗi số 2 chữ số thập phân, ví dụ (3.00, 4.00).

import java.util.*;


class Vec2 {
    double x, y;
   
    // Constructor khởi tạo tọa độ cho Vector
    Vec2(double x, double y) {
        this.x = x;
        this.y = y;
    }


    // Cộng hai vector: Trả về một đối tượng Vec2 mới
    Vec2 add(Vec2 o) {
        return new Vec2(this.x + o.x, this.y + o.y);
    }


    // Trừ hai vector: Trả về một đối tượng Vec2 mới
    Vec2 sub(Vec2 o) {
        return new Vec2(this.x - o.x, this.y - o.y);
    }


    // Tính tích vô hướng (Dot Product)
    double dot(Vec2 o) {
        return this.x * o.x + this.y * o.y;
    }


    // Tính độ dài (Magnitude) của vector dùng định lý Pitago
    double length() {
        return Math.sqrt(this.x * this.x + this.y * this.y);
    }


    // Ghi đè phương thức toString() định dạng chính xác chuỗi (x, y)
    @Override
    public String toString() {
        return String.format(Locale.US, "(%.2f, %.2f)", this.x, this.y);
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng test case trống từ hệ thống OJ
        if (!sc.hasNextInt()) return;
        int q = sc.nextInt();
       
        // Xử lý Q truy vấn tuần tự
        for (int i = 0; i < q; i++) {
            double x1 = sc.nextDouble();
            double y1 = sc.nextDouble();
            double x2 = sc.nextDouble();
            double y2 = sc.nextDouble();
            String op = sc.next();
           
            // Khởi tạo 2 đối tượng vector dựa trên tọa độ nhập vào
            Vec2 v1 = new Vec2(x1, y1);
            Vec2 v2 = new Vec2(x2, y2);
           
            // Lựa chọn xử lý dựa trên toán tử op nhập vào
            if (op.equals("ADD")) {
                System.out.println(v1.add(v2)); // Tự động kích hoạt hàm toString() của Vec2
            } else if (op.equals("SUB")) {
                System.out.println(v1.sub(v2));
            } else if (op.equals("DOT")) {
                System.out.printf(Locale.US, "%.2f\n", v1.dot(v2));
            } else if (op.equals("LEN1")) {
                System.out.printf(Locale.US, "%.2f\n", v1.length());
            } else if (op.equals("LEN2")) {
                System.out.printf(Locale.US, "%.2f\n", v2.length());
            }
        }
       
        sc.close();
    }
}

Cho danh sách N học sinh: name (String), score (double).
Sử dụng Collectors.partitioningBy để chia học sinh thành 2 nhóm:
PASS: score ≥ ngưỡng threshold (đọc từ stdin)
FAIL: score < threshold
import java.util.*;
import java.util.stream.*;


class S {
    String name;
    double score;
   
    S(String n, double s) {
        name = n;
        score = s;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        List<S> list = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            list.add(new S(sc.next(), sc.nextDouble()));
        }
       
        if (!sc.hasNextDouble()) return;
        double threshold = sc.nextDouble();


        // 1. Phân hoạch học sinh thành 2 nhóm ĐỖ (true) và TRƯỢT (false) dựa trên ngưỡng threshold
        Map<Boolean, List<S>> partitionedMap = list.stream()
                .collect(Collectors.partitioningBy(student -> student.score >= threshold));


        // Lấy danh sách cụ thể của 2 nhóm
        List<S> passList = partitionedMap.get(true);
        List<S> failList = partitionedMap.get(false);


        // 2. Định nghĩa quy tắc so sánh để tìm ra thủ khoa (Top) của nhóm
        Comparator<S> studentComparator = (s1, s2) -> {
            if (Double.compare(s1.score, s2.score) != 0) {
                return Double.compare(s1.score, s2.score); // Sắp xếp điểm tăng dần
            }
            // Nếu điểm bằng nhau, tên theo alphabet lớn hơn đứng trước (để tên nhỏ hơn đứng sau làm max)
            return s2.name.compareTo(s1.name);
        };


        // 3. Tiến hành thống kê và in kết quả cho nhóm PASS (Khóa true)
        int passCount = passList.size();
        double passAvg = passList.stream().mapToDouble(s -> s.score).average().orElse(0.0);
        String passTop = passList.stream()
                                 .max(studentComparator)
                                 .map(s -> s.name)
                                 .orElse("-");
       
        System.out.printf(Locale.US, "PASS %d %.2f %s\n", passCount, passAvg, passTop);


        // 4. Tiến hành thống kê và in kết quả cho nhóm FAIL (Khóa false)
        int failCount = failList.size();
        double failAvg = failList.stream().mapToDouble(s -> s.score).average().orElse(0.0);
        String failTop = failList.stream()
                                 .max(studentComparator)
                                 .map(s -> s.name)
                                 .orElse("-");
       
        System.out.printf(Locale.US, "FAIL %d %.2f %s\n", failCount, failAvg, failTop);


        sc.close();
    }
}
