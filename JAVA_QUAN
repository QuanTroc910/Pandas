        float m2 = sc.nextFloat();


        // c. Khởi tạo các đối tượng bằng từ khóa new và nạp tham số
        IMathOperation addOp = new Addition(a1, a2);
        IMathOperation subOp = new Subtraction(s1, s2);
        IMathOperation mulOp = new Multiplication(m1, m2);


        // Gọi phương thức showInfo() để hệ thống tự xử lý tính toán và in kết quả
        addOp.showInfo();
        subOp.showInfo();
        mulOp.showInfo();
       
        sc.close();
    }
}
Đề bài 38: Một lớp học có danh sách sinh viên, mỗi sinh viên gồm tên và điểm trung bình. Hãy sử dụng Functional Interface Consumer<T> trong Java để:
In ra thông tin từng sinh viên (tên và điểm).
Xếp loại học lực cho mỗi sinh viên dựa trên điểm số như sau:
Điểm ≥ 8.0: Giỏi
6.5 ≤ Điểm < 8.0: Khá
5.0 ≤ Điểm < 6.5: Trung bình
Điểm < 5.0: Yếu
Bài làm:
import java.util.*;
import java.util.function.Consumer;


class Student {
    String name;
    double score;


    Student(String name, double score) {
        this.name = name;
        this.score = score;
    }
}


public class Main {
    public static void main(String[] args) {


        // Danh sách sinh viên khởi tạo sẵn
        List<Student> students = Arrays.asList(
                new Student("An", 9.0),
                new Student("Binh", 7.2),
                new Student("Chi", 6.4),
                new Student("Dung", 4.8),
                new Student("Hoa", 8.5)
        );


        // 1. Consumer 1: In thông tin sinh viên (dùng print để không xuống dòng)
        Consumer<Student> printInfo = s -> System.out.print("Tên: " + s.name + " | Điểm: " + s.score);


        // 2. Consumer 2: Xếp loại học lực dựa trên điểm (dùng println để xuống dòng ở cuối)
        Consumer<Student> classify = s -> {
            String hocLuc;
            if (s.score >= 8.0) {
                hocLuc = "Giỏi";
            } else if (s.score >= 6.5) {
                hocLuc = "Khá";
            } else if (s.score >= 5.0) {
                hocLuc = "Trung bình";
            } else {
                hocLuc = "Yếu";
            }
            System.out.println(" | Học lực: " + hocLuc);
        };


        // 3. Kết hợp hai Consumer bằng .andThen() (Hệ thống đã viết sẵn)
        Consumer<Student> combined = printInfo.andThen(classify);
        students.forEach(combined);
    }
}

