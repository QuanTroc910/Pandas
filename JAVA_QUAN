Cho N cặp (key, value) với key là chuỗi (không trùng nhau), value là số nguyên.
Hãy đưa các cặp vào HashMap<String, Integer>, sau đó sắp xếp các entry theo value giảm dần. Nếu hai value bằng nhau, sắp theo key tăng dần (alphabet).
import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        HashMap<String, Integer> map = new HashMap<>();
       
        // 1. Đọc N cặp dữ liệu và nạp trực tiếp vào HashMap
        for (int i = 0; i < n; i++) {
            String key = sc.next();
            int value = sc.nextInt();
            map.put(key, value);
        }


        // 2. Chuyển đổi entrySet của Map sang một cấu trúc ArrayList để chuẩn bị sắp xếp
        List<Map.Entry<String, Integer>> entryList = new ArrayList<>(map.entrySet());


        // 3. Sử dụng Collections.sort kết hợp Comparator tùy biến để sắp xếp đa tiêu chí
        Collections.sort(entryList, new Comparator<Map.Entry<String, Integer>>() {
            @Override
            public int compare(Map.Entry<String, Integer> e1, Map.Entry<String, Integer> e2) {
                // Tiêu chí 1: So sánh theo Giá trị (Value) giảm dần
                // Truyền e2 trước e1 để đảo ngược thứ tự thành giảm dần
                int valueCompare = Integer.compare(e2.getValue(), e1.getValue());
               
                if (valueCompare != 0) {
                    return valueCompare;
                }
               
                // Tiêu chí 2 (Tie-break): Nếu hai Value bằng nhau, sắp theo Khóa (Key) alphabet tăng dần
                return e1.getKey().compareTo(e2.getKey());
            }
        });


        // 4. Duyệt danh sách Entry đã được sắp xếp để in ra kết quả đầu ra đúng chuẩn định dạng
        for (Map.Entry<String, Integer> entry : entryList) {
            System.out.println(entry.getKey() + " " + entry.getValue());
        }
       
        sc.close();
    }
}

Tạo 2 thread: thread A và thread B. Cùng dùng một biến chung và một lock. Yêu cầu in ra ABABAB... với A và B xuất hiện đúng N lần.
Dùng object lock chung và biến turn (0 = đến lượt A, 1 = đến lượt B).
import java.util.*;


public class Main {
    static final Object lock = new Object();
    static int turn = 0; // 0 = lượt của A, 1 = lượt của B
    static StringBuilder out = new StringBuilder();


    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNextLine()) return;
        int n = Integer.parseInt(sc.nextLine().trim());


        // 1. Khởi tạo Thread A phụ trách việc ghi ký tự 'A'
        Thread threadA = new Thread(() -> {
            for (int i = 0; i < n; i++) {
                synchronized (lock) {
                    // Dùng vòng lặp while kiểm tra điều kiện để tránh hiện tượng "đánh thức giả tạo" (Spurious Wakeup)
                    while (turn != 0) {
                        try {
                            lock.wait(); // Nhường quyền và ngủ đông chờ đến lượt
                        } catch (InterruptedException e) {
                            Thread.currentThread().interrupt();
                        }
                    }
                   
                    // Thực hiện tác vụ khi đã đến lượt
                    out.append('A');
                   
                    // Chuyển lượt sang cho luồng B và phát tín hiệu đánh thức tất cả các luồng đang đợi
                    turn = 1;
                    lock.notifyAll();
                }
            }
        });


        // 2. Khởi tạo Thread B phụ trách việc ghi ký tự 'B'
        Thread threadB = new Thread(() -> {
            for (int i = 0; i < n; i++) {
                synchronized (lock) {
                    while (turn != 1) {
                        try {
                            lock.wait(); // Nhường quyền và ngủ đông chờ đến lượt
                        } catch (InterruptedException e) {
                            Thread.currentThread().interrupt();
                        }
                    }
                   
                    // Thực hiện tác vụ khi đã đến lượt
                    out.append('B');
                   
                    // Chuyển lượt ngược lại cho luồng A và phát tín hiệu đánh thức
                    turn = 0;
                    lock.notifyAll();
                }
            }
        });


        // 3. Kích hoạt cho cả 2 luồng đồng thời chạy song song
        threadA.start();
        threadB.start();


        // 4. Ép luồng main phải đứng đợi cho đến khi cả 2 luồng phụ hoàn thành xong trọn vẹn N vòng lặp
        threadA.join();
        threadB.join();


        // 5. In ra chuỗi kết quả tích lũy hoàn chỉnh theo đúng định dạng mẫu
        System.out.println(out.toString());


        sc.close();
    }
}

