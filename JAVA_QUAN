In ra số lượng từ duy nhất:
import java.io.*;
import java.util.*;


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
        String path = "text.txt";


        // 1. Đọc dữ liệu từ bàn phím (stdin) cho đến khi gặp EOF và ghi vào file text.txt bằng FileWriter
        try (FileWriter fw = new FileWriter(path)) {
            while (sc.hasNextLine()) {
                fw.write(sc.nextLine());
                if (sc.hasNextLine()) {
                    fw.write("\n"); // Ghi dấu xuống dòng nếu vẫn còn dòng tiếp theo
                }
            }
        }


        // Khởi tạo HashSet để tự động lọc và lưu trữ các từ duy nhất
        HashSet<String> uniqueWords = new HashSet<>();


        // 2. Đọc lại file text.txt bằng BufferedReader để bóc tách từ
        try (BufferedReader br = new BufferedReader(new FileReader(path))) {
            String line;
            while ((line = br.readLine()) != null) {
                // Thực hiện trim() loại bỏ khoảng trắng ở rìa biên
                String trimmedLine = line.trim();
               
                // Nếu dòng rỗng sau khi trim thì bỏ qua
                if (trimmedLine.isEmpty()) {
                    continue;
                }
               
                // Tách dòng thành mảng các từ bằng một hoặc nhiều khoảng trắng liên tiếp
                String[] words = trimmedLine.split("\\s+");
               
                // Duyệt qua từng từ, chuyển về chữ thường và thêm vào HashSet
                for (String word : words) {
                    uniqueWords.add(word.toLowerCase());
                }
            }
        }


        // 3. In ra số lượng từ duy nhất theo đúng định dạng yêu cầu của hệ thống
        System.out.println("unique: " + uniqueWords.size());


        sc.close();
    }
}
Một ngân hàng cung cấp hai loại tài khoản: tiết kiệm và thanh toán, đều thừa kế chung từ lớp trừu tượng Account. 

import java.util.*;


// Lớp trừu tượng Account hệ thống đã khai báo cấu trúc
abstract class Account {
    String id;
    String holder;
    double balance;


    public Account(String id, String holder, double balance) {
        this.id = id;
        this.holder = holder;
        this.balance = balance;
    }


    // Phương thức trừu tượng tính tiền lãi cuối kỳ
    abstract double interest();


    // Phương thức nạp tiền chung cho tất cả các loại tài khoản
    void deposit(double amount) {
        this.balance += amount;
    }
}


// Lớp SavingsAccount (Tài khoản tiết kiệm) kế thừa Account
class SavingsAccount extends Account {
    double rate;


    public SavingsAccount(String id, String holder, double balance, double rate) {
        super(id, holder, balance);
        this.rate = rate;
    }


    @Override
    double interest() {
        // Công thức tính lãi tiết kiệm: số dư * lãi suất
        return this.balance * this.rate;
    }
}


// Lớp CheckingAccount (Tài khoản thanh toán) kế thừa Account
class CheckingAccount extends Account {
    double monthlyFee;


    public CheckingAccount(String id, String holder, double balance, double monthlyFee) {
        super(id, holder, balance);
        this.monthlyFee = monthlyFee;
    }


    @Override
    double interest() {
        // Công thức tính lãi thanh toán: số dư * 1% - phí duy trì * 12 tháng
        return this.balance * 0.01 - this.monthlyFee * 12;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng test case trống từ hệ thống OJ
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        List<Account> accountList = new ArrayList<>();
        Map<String, Account> accountMap = new HashMap<>();
       
        // 1. Đọc thông tin N tài khoản
        for (int i = 0; i < n; i++) {
            String type = sc.next();
            String id = sc.next();
            String holder = sc.next();
            double balance = sc.nextDouble();
           
            Account acc = null;
            if (type.equals("SAV")) {
                double rate = sc.nextDouble();
                acc = new SavingsAccount(id, holder, balance, rate);
            } else if (type.equals("CHK")) {
                double monthlyFee = sc.nextDouble();
                acc = new CheckingAccount(id, holder, balance, monthlyFee);
            }
           
            if (acc != null) {
                accountList.add(acc);   // Giữ thứ tự nhập để in ra sau này
                accountMap.put(id, acc); // Map để hỗ trợ tra cứu nhanh bằng ID
            }
        }
       
        if (!sc.hasNextInt()) return;
        int m = sc.nextInt();
       
        // 2. Xử lý M giao dịch nạp tiền
        for (int i = 0; i < m; i++) {
            String id = sc.next();
            double amount = sc.nextDouble();
           
            Account acc = accountMap.get(id);
            if (acc != null) {
                acc.deposit(amount); // Nạp tiền trực tiếp vào tài khoản tìm được
            }
        }
       
        double totalInterest = 0;
       
        // 3. Duyệt danh sách theo đúng thứ tự nhập để in kết quả và cộng dồn tổng lãi
        for (Account acc : accountList) {
            double interest = acc.interest(); // Tính toán đa hình tùy loại tài khoản thực tế
            totalInterest += interest;
           
            // In kết quả tài khoản hiện tại làm tròn 2 chữ số thập phân
            System.out.printf("%s %.2f %.2f\n", acc.id, acc.balance, interest);
        }
       
        // 4. In dòng tổng kết cuối cùng
        System.out.printf("TOTAL_INTEREST %.2f\n", totalInterest);
       
        sc.close();
    }
}
Cho danh sách sản phẩm gồm name (String), category (String), price (double), stock (int).
Sử dụng Stream API thực hiện theo thứ tự:
import java.util.*;
import java.util.stream.*;


// Định nghĩa lớp Product để quản lý dữ liệu sản phẩm
class Product {
    String name;
    String category;
    double price;
    int stock;


    public Product(String name, String category, double price, int stock) {
        this.name = name;
        this.category = category;
        this.price = price;
        this.stock = stock;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống từ hệ thống OJ
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        List<Product> list = new ArrayList<>();
        // Nhập thông tin của N sản phẩm
        for (int i = 0; i < n; i++) {
            String name = sc.next();
            String category = sc.next();
            double price = sc.nextDouble();
            int stock = sc.nextInt();
            list.add(new Product(name, category, price, stock));
        }
       
        if (!sc.hasNextDouble()) return;
        double minPrice = sc.nextDouble();


        // Xây dựng Stream pipeline để lọc, sắp xếp và biến đổi dữ liệu
        List<String> filteredAndSortedProducts = list.stream()
            // 1. Lọc các sản phẩm còn hàng trong kho (stock > 0)
            .filter(p -> p.stock > 0)
            // 2. Lọc thêm các sản phẩm có mức giá từ minPrice trở lên
            .filter(p -> p.price >= minPrice)
            // 3. Sắp xếp: giá giảm dần, nếu bằng giá thì xếp tên alphabet tăng dần
            .sorted((p1, p2) -> {
                if (Double.compare(p1.price, p2.price) != 0) {
                    return Double.compare(p2.price, p1.price); // Giá giảm dần
                }
                return p1.name.compareTo(p2.name); // Tên tăng dần
            })
            // 4. Ánh xạ mỗi đối tượng Product thành chuỗi định dạng yêu cầu (price lấy 2 chữ số thập phân)
            .map(p -> String.format("%s|%s|%.2f", p.name, p.category, p.price))
            // 5. Thu gom toàn bộ chuỗi kết quả vào một danh sách để kiểm soát đầu ra
            .collect(Collectors.toList());


        // In danh sách sản phẩm hợp lệ đã được xử lý ra màn hình
        for (String outputLine : filteredAndSortedProducts) {
            System.out.println(outputLine);
        }


        // In dòng tổng kết số lượng sản phẩm khớp hoàn toàn định dạng mẫu
        System.out.println("COUNT " + filteredAndSortedProducts.size());


        sc.close();
    }
}
