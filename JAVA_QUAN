Viết chương trình:
Đọc N từ stdin, sau đó N số nguyên 0..255 (mỗi số là 1 byte).
Ghi N byte đó vào file src.bin bằng FileOutputStream.
Sao chép src.bin sang dst.bin bằng FileInputStream + FileOutputStream với buffer kích thước 512 byte.
Đọc lại dst.bin, tính checksum (sum mod 65536 — coi mỗi byte là unsigned 0..255).


import java.io.*;
import java.util.*;


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
        String srcFile = "src.bin";
        String dstFile = "dst.bin";


        // Chốt chặn an toàn kiểm tra dữ liệu đầu vào rỗng của hệ thống chấm bài
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();


        // 1. Đọc N số nguyên từ bàn phím và ghi trực tiếp xuống src.bin
        try (FileOutputStream fosSrc = new FileOutputStream(srcFile)) {
            for (int i = 0; i < n; i++) {
                // write(int) sẽ tự động cắt lấy 8 bit cuối cùng (tương đương 1 byte)
                fosSrc.write(sc.nextInt());
            }
            fosSrc.flush();
        }


        // 2. Sao chép từ src.bin sang dst.bin sử dụng buffer kích thước 512 byte
        try (
            FileInputStream fisSrc = new FileInputStream(srcFile);
            FileOutputStream fosDst = new FileOutputStream(dstFile)
        ) {
            byte[] buffer = new byte[512]; // Gầu xúc 512 byte
            int bytesRead;
            // Đọc dữ liệu vào buffer, hàm trả về số byte thực tế đọc được, kết thúc trả về -1
            while ((bytesRead = fisSrc.read(buffer)) != -1) {
                // Ghi dữ liệu từ buffer ra file, từ vị trí 0, với số lượng là bytesRead
                fosDst.write(buffer, 0, bytesRead);
            }
            fosDst.flush();
        }


        // 3. Đọc lại dst.bin để đếm size và tính checksum
        int size = 0;
        long sum = 0;
        try (FileInputStream fisDst = new FileInputStream(dstFile)) {
            int b;
            // fisDst.read() tự động trả về giá trị unsigned từ 0..255 (trả về -1 nếu hết file)
            while ((b = fisDst.read()) != -1) {
                size++;
                sum += b;
            }
        }


        // 4. Tính Checksum (sum mod 65536) và in kết quả ra màn hình
        long checksum = sum % 65536;
       
        System.out.println("size: " + size);
        System.out.println("checksum: " + checksum);


        sc.close();
    }
}


