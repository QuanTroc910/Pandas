        this.from = from;
        this.to = to;
    }


    // Logic đảo ngược chuỗi trực tiếp trên mảng chạy song song
    @Override
    public void run() {
        for (int i = from; i < to; i++) {
            if (arr[i] != null) {
                // Sử dụng StringBuilder.reverse() để đảo ngược chuỗi in-place
                arr[i] = new StringBuilder(arr[i]).reverse().toString();
            }
        }
    }
}


