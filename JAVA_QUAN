import java.util.*;
import java.util.function.*;
import java.util.stream.*;


class Employee {
    String name;
    int age;


    Employee(String name, int age) {
        this.name = name;
        this.age = age;
    }
   
    // Getter bổ sung giúp gọi hàm chính xác trong Stream
    public int getAge() {
        return age;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);


        if (!sc.hasNextLine()) return;
        int N = Integer.parseInt(sc.nextLine().trim());
        List<Employee> list = new ArrayList<>();


        for (int i = 0; i < N; i++) {
            String[] parts = sc.nextLine().split(" ");
            list.add(new Employee(parts[0], Integer.parseInt(parts[1])));
        }


        // 1. Predicate: Lọc ra những nhân viên có tuổi >= 25
        Predicate<Employee> ageFilter = emp -> emp.age >= 25;


        // 2. Function: Ánh xạ mỗi nhân viên sang chuỗi dạng "Tên - Tuổi"
        Function<Employee, String> stringMapper = emp -> emp.name + " - " + emp.age;


        // 3. BinaryOperator: Chọn chuỗi có độ dài lớn hơn khi xảy ra xung đột trùng Key (trùng tuổi)
        BinaryOperator<String> lengthMerger = (str1, str2) -> str1.length() >= str2.length() ? str1 : str2;


        // 4. Comparator: Bộ so sánh giảm dần theo tuổi (dùng làm Key cho TreeMap)
        Comparator<Integer> ageDescendingOrder = (age1, age2) -> Integer.compare(age2, age1);


        // --- Áp dụng toàn bộ các đối tượng trên vào Stream pipeline ---
        Map<Integer, String> processedMap = list.stream()
                .filter(ageFilter) // Bước 1: Lọc dữ liệu
                // Tiến hành gom nhóm vào TreeMap để tự động quản lý xung đột và sắp xếp giảm dần theo Key (tuổi)
                .collect(Collectors.toMap(
                        Employee::getAge,        // Key của Map là Tuổi
                        stringMapper,            // Value của Map là chuỗi đã qua biến đổi từ Function
                        lengthMerger,            // Bộ giải quyết xung đột bằng BinaryOperator nếu trùng tuổi
                        () -> new TreeMap<>(ageDescendingOrder) // Đưa vào TreeMap cấu hình sort giảm dần theo Key
                ));


        // 5. In danh sách kết quả ra màn hình (các Value trong TreeMap đã được sắp xếp giảm dần theo tuổi)
        processedMap.values().forEach(System.out::println);
        sc.close();
    }
}
Mô phỏng mô hình Producer / Consumer sử dụng LinkedBlockingQueue<Integer> capacity = 100.
Có P producer thread, mỗi producer sẽ put các số nguyên 1, 2, …, M_i vào queue.

import java.util.*;
import java.util.concurrent.*;
import java.util.concurrent.atomic.AtomicLong;


public class Main {
   
    // Định nghĩa lớp Producer (Nhà sản xuất)
    static class Producer extends Thread {
        private final BlockingQueue<Integer> queue;
        private final int maxNumber;


        public Producer(BlockingQueue<Integer> queue, int maxNumber) {
            this.queue = queue;
            this.maxNumber = maxNumber;
        }


        @Override
        public void run() {
            try {
                // Đẩy tuần tự các số nguyên từ 1 đến maxNumber vào hàng đợi
                for (int i = 1; i <= maxNumber; i++) {
                    queue.put(i); // Hàm put() tự động block nếu queue đầy (capacity = 100)
                }
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }
    }


    // Định nghĩa lớp Consumer (Người tiêu thụ)
    static class Consumer extends Thread {
        private final BlockingQueue<Integer> queue;
        private final AtomicLong total;


        public Consumer(BlockingQueue<Integer> queue, AtomicLong total) {
            this.queue = queue;
            this.total = total;
        }


        @Override
        public void run() {
            try {
                while (true) {
                    // Lấy dữ liệu từ hàng đợi (tự động block nếu queue rỗng)
                    int val = queue.take();
                   
                    // Gặp giá trị kết thúc (Sentinel Value) thì dừng luồng
                    if (val == -1) {
                        break;
                    }
                   
                    // Cộng dồn an toàn đa luồng vào biến total
                    total.addAndGet(val);
                }
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            }
        }
    }


    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào tránh lỗi hệ thống OJ khi quét file trống
        if (!sc.hasNextInt()) return;
        int P = sc.nextInt();
        int C = sc.nextInt();
       
        int[] M = new int[P];
        for (int i = 0; i < P; i++) {
            M[i] = sc.nextInt();
        }


        BlockingQueue<Integer> queue = new LinkedBlockingQueue<>(100);
        AtomicLong total = new AtomicLong();


        // 1. Khởi tạo và kích hoạt chạy song song P producer
        Producer[] producers = new Producer[P];
        for (int i = 0; i < P; i++) {
            producers[i] = new Producer(queue, M[i]);
            producers[i].start();
        }


        // 2. Khởi tạo và kích hoạt chạy song song C consumer
        Consumer[] consumers = new Consumer[C];
        for (int i = 0; i < C; i++) {
            consumers[i] = new Consumer(queue, total);
            consumers[i].start();
        }


        // 3. Ép luồng main đứng đợi cho đến khi TẤT CẢ các Producer đã hoàn thành việc sản xuất
        for (int i = 0; i < P; i++) {
            producers[i].join();
        }


        // 4. Sau khi các Producer xong, luồng main đẩy C giá trị -1 vào để ra hiệu dừng cho C luồng Consumer
        for (int i = 0; i < C; i++) {
            queue.put(-1);
        }


        // 5. Ép luồng main đợi cho đến khi tất cả các Consumer nhận tín hiệu -1 và kết thúc xử lý hoàn toàn
        for (int i = 0; i < C; i++) {
            consumers[i].join();
        }


        // 6. In ra tổng giá trị cuối cùng tích lũy được trong AtomicLong
        System.out.println(total.get());


        sc.close();
    }
}
