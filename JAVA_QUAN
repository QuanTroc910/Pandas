    }
}
Cho một mảng gồm N số nguyên dương. Với mỗi phần tử aᵢ, ta tính tổng tất cả ước số của nó, ví dụ:
Ước số của 6: 1 + 2 + 3 + 6 = 12
Ước số của 10: 1 + 2 + 5 + 10 = 18
import java.util.*;


// 1. Định nghĩa class luồng kế thừa từ Thread
class DivisorThread extends Thread {
    private int[] arr;
    private int start, end;
    private long totalSum = 0; // Lưu kết quả tổng ước số của đoạn này


    // Hàm khởi tạo (Constructor) để nạp dữ liệu cho từng luồng
    public DivisorThread(int[] arr, int start, int end) {
        this.arr = arr;
        this.start = start;
        this.end = end;
    }


    // Hàm tính tổng các ước số của một số nguyên dương x tối ưu bằng O(sqrt(x))
    private long sumOfDivisors(int x) {
        long sum = 0;
        for (int i = 1; i * i <= x; i++) {
            if (x % i == 0) {
                sum += i;
                if (i * i != x) {
                    sum += x / i;
                }
            }
        }
        return sum;
    }


    // Trái tim của Thread: Code trong hàm run() này sẽ chạy song song
    @Override
    public void run() {
        for (int i = start; i < end; i++) {
            totalSum += sumOfDivisors(arr[i]);
        }
    }


    // Hàm phụ để lấy kết quả sau khi luồng chạy xong
    public long getTotalSum() {
        return totalSum;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào tránh lỗi NoSuchElement của hệ thống OJ
        if (!sc.hasNextInt()) return;
        int N = sc.nextInt();
       
        int[] arr = new int[N];
        for (int i = 0; i < N; i++) {
            arr[i] = sc.nextInt();
        }
        int K = sc.nextInt();
       
        // Tạo một mảng quản lý K luồng
        DivisorThread[] threads = new DivisorThread[K];
       
        // Chia việc cho K luồng
        int baseSize = N / K; // Số lượng phần tử tối thiểu mỗi luồng phải làm
        int remainder = N % K; // Số phần tử dư ra
       
        int currentStart = 0;
        for (int i = 0; i < K; i++) {
            // Nếu còn dư phần tử thì luồng này gánh thêm 1 phần tử
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);
           
            // Tạo luồng mới và giao đoạn mảng từ currentStart đến currentEnd
            threads[i] = new DivisorThread(arr, currentStart, currentEnd);
           
            // Kích hoạt luồng chạy (gọi hàm start() chứ không gọi run())
            threads[i].start();
           
            // Cập nhật vị trí bắt đầu cho luồng tiếp theo
            currentStart = currentEnd;
        }
       
        long finalResult = 0;
       
        // Đợi tất cả các luồng làm xong rồi cộng dồn kết quả
        for (int i = 0; i < K; i++) {
            try {
                // Lệnh join() bắt hàm main phải đợi luồng i chạy xong hoàn toàn mới làm tiếp
                threads[i].join();
                finalResult += threads[i].getTotalSum();
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
       
        // In ra tổng cuối cùng
        System.out.println(finalResult);
        sc.close();
    }
}
Câu 41:Cho mảng N số nguyên (có thể âm và 0). Hãy tính tích của các phần tử dương modulo 10⁹+7, sử dụng K thread chia việc. 
import java.util.*;


// Định nghĩa lớp ProdThread kế thừa từ Thread
class ProdThread extends Thread {
    int[] arr;
    int from, to;
    long local = 1L; // Tích khởi tạo bằng 1 (quy ước tích rỗng)
    static final long MOD = 1_000_000_007L;


    // Constructor gán dữ liệu phân đoạn mảng cho luồng
    public ProdThread(int[] arr, int from, int to) {
        this.arr = arr;
        this.from = from;
        this.to = to;
    }


    // Logic tính tích các số dương cục bộ thuộc phạm vi quản lý
    @Override
    public void run() {
        for (int i = from; i < to; i++) {
            if (arr[i] > 0) {
                // Nhân và lấy Modulo ngay lập tức để tránh tràn số
                local = (local * (arr[i] % MOD)) % MOD;
            }
        }
    }
}


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }
        int k = sc.nextInt();


        // Tạo mảng quản lý K luồng xử lý song song
        ProdThread[] threads = new ProdThread[k];


        // Thuật toán chia đoạn mảng đều cho K luồng
        int baseSize = n / k;
        int remainder = n % k;


        int currentStart = 0;
        for (int i = 0; i < k; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);


            // Khởi tạo luồng và kích hoạt chạy song song
            threads[i] = new ProdThread(arr, currentStart, currentEnd);
            threads[i].start();


            currentStart = currentEnd;
        }


        long finalResult = 1L; // Kết quả tổng hợp cuối cùng ban đầu bằng 1
        long MOD = ProdThread.MOD;


        // Chờ các luồng hoàn thành nhiệm vụ và gom kết quả tích cục bộ
        for (int i = 0; i < k; i++) {
            threads[i].join(); // Đợi luồng i chạy xong
           
            // Nhân tích cục bộ của luồng i vào kết quả tổng và tiếp tục Modulo
            finalResult = (finalResult * threads[i].local) % MOD;
        }


        // In kết quả tích cuối cùng ra màn hình
        System.out.println(finalResult);


        sc.close();
    }
}

