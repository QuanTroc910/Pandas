import java.io.*;
import java.nio.charset.StandardCharsets;
import java.util.*;


public class Main {
   
    // Phương thức phụ giúp chuẩn hóa họ tên sinh viên đúng quy tắc
    private static String normalizeName(String name) {
        String trimmed = name.trim();
        if (trimmed.isEmpty()) return "";
       
        // Cắt chuỗi dựa trên một hoặc nhiều khoảng trắng liên tiếp
        String[] words = trimmed.split("\\s+");
        StringBuilder sb = new StringBuilder();
       
        for (String word : words) {
            if (!word.isEmpty()) {
                // Viết hoa chữ đầu, viết thường các chữ sau
                String capitalizedWord = Character.toUpperCase(word.charAt(0))
                        + word.substring(1).toLowerCase();
                sb.append(capitalizedWord).append(" ");
            }
        }
        // Trả về chuỗi và loại bỏ dấu cách thừa ở cuối cùng
        return sb.toString().trim();
    }


    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        List<String> students = new ArrayList<>();
        String filePath = "students.txt";


        // 1. Đọc danh sách sinh viên từ bàn phím cho đến khi gặp dòng trống
        while (sc.hasNextLine()) {
            String line = sc.nextLine();
            if (line.trim().isEmpty()) {
                break;
            }
            // Chuẩn hóa tên ngay khi nhận dữ liệu đầu vào và đưa vào danh sách
            students.add(normalizeName(line));
        }


        // 2. Sử dụng OutputStreamWriter (thông qua BufferedWriter) cấu hình UTF-8 để ghi dữ liệu vào file
        try (BufferedWriter writer = new BufferedWriter(
                new OutputStreamWriter(new FileOutputStream(filePath), StandardCharsets.UTF_8))) {
           
            // Ghi danh sách sinh viên đã chuẩn hóa
            for (String student : students) {
                writer.write(student);
                writer.newLine();
            }
            // Ghi thêm dòng thống kê số lượng sinh viên ở cuối file
            writer.write("Số lượng sinh viên: " + students.size());
            writer.flush(); // Đẩy toàn bộ dữ liệu từ bộ đệm xuống đĩa cứng
           
        } catch (IOException e) {
            e.printStackTrace();
        }


        // 3. Sử dụng InputStreamReader (thông qua BufferedReader) cấu hình UTF-8 để đọc và in ra màn hình
        try (BufferedReader reader = new BufferedReader(
                new InputStreamReader(new FileInputStream(filePath), StandardCharsets.UTF_8))) {
           
            String currentLine;
            // Đọc tuần tự từng dòng trong file students.txt cho đến hết dữ liệu (null)
            while ((currentLine = reader.readLine()) != null) {
                System.out.println(currentLine);
            }
           
        } catch (IOException e) {
            e.printStackTrace();
        }


        sc.close();
    }
}
