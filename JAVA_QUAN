        int n = sc.nextInt(); // nhập 1 số
        sc.close();


        // 1. Predicate kiểm tra số chẵn
        Predicate<Integer> isEven = x -> x % 2 == 0;


        // 2. Predicate kiểm tra lớn hơn 50
        Predicate<Integer> greaterThan50 = x -> x > 50;


        // Kết hợp 2 điều kiện: vừa chẵn, vừa > 50 (Hệ thống đã viết sẵn dòng này)
        Predicate<Integer> evenAndGreater50 = isEven.and(greaterThan50);


        // 3. Sử dụng Predicate bằng hàm .test() để kiểm tra số đầu vào n
        if (evenAndGreater50.test(n)) {
            System.out.println("Đúng");
        } else {
            System.out.println("Sai");
        }
    }
}

