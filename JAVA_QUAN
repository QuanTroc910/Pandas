import java.util.*;


// 1. Định nghĩa class luồng tính giai thừa kế thừa từ Thread
class FactThread extends Thread {
    private int[] arr;
    private int start, end;
    private long totalSum = 0; // Bắt buộc dùng kiểu long để tránh tràn số


    // Constructor để nạp đoạn mảng cần xử lý
    public FactThread(int[] arr, int start, int end) {
        this.arr = arr;
        this.start = start;
        this.end = end;
    }


    // Hàm phụ dùng để tính giai thừa của một số nguyên x
    private long tinhGiaiThua(int x) {
        long giaiThua = 1;
        for (int i = 1; i <= x; i++) {
            giaiThua *= i;
        }
        return giaiThua;
    }


    // Logic tính tổng giai thừa của đoạn mảng được giao
    @Override
    public void run() {
        for (int i = start; i < end; i++) {
            totalSum += tinhGiaiThua(arr[i]);
        }
    }


    // Hàm lấy kết quả tổng giai thừa của riêng luồng này
    public long getTotalSum() {
        return totalSum;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        int N = sc.nextInt();
        int[] arr = new int[N];
        for (int i = 0; i < N; i++) {
            arr[i] = sc.nextInt();
        }
        int K = sc.nextInt();
       
        // Tạo mảng quản lý K luồng
        FactThread[] threads = new FactThread[K];
       
        // Chia việc phân đoạn mảng cho K luồng
        int baseSize = N / K;
        int remainder = N % K;
       
        int currentStart = 0;
        for (int i = 0; i < K; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);
           
            // Khởi tạo và kích hoạt luồng i chạy song song
            threads[i] = new FactThread(arr, currentStart, currentEnd);
            threads[i].start();
           
            currentStart = currentEnd;
        }
       
        // Biến lưu tổng giai thừa cuối cùng của toàn mảng
        long finalResult = 0;
       
        // Đợi tất cả các luồng làm xong để thu hoạch kết quả
        for (int i = 0; i < K; i++) {
            try {
                threads[i].join(); // Chờ luồng i hoàn thành công việc
                finalResult += threads[i].getTotalSum();
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
       
        // In ra tổng kết quả cuối cùng
        System.out.println(finalResult);
