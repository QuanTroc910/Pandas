import java.util.*;


// 1. Định nghĩa class luồng tìm Max kế thừa từ Thread
class MaxThread extends Thread {
    private int[] arr;
    private int start, end;
    private int maxVal = Integer.MIN_VALUE; // Khởi tạo max bằng số nhỏ nhất có thể


    // Constructor nhận đoạn mảng cần xử lý
    public MaxThread(int[] arr, int start, int end) {
        this.arr = arr;
        this.start = start;
        this.end = end;
    }


    // Logic tìm max của đoạn [start, end) chạy song song
    @Override
    public void run() {
        for (int i = start; i < end; i++) {
            if (arr[i] > maxVal) {
                maxVal = arr[i];
            }
        }
    }


    // Hàm phụ để lấy kết quả max của luồng này
    public int getMaxVal() {
        return maxVal;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        int N = sc.nextInt();
        int[] arr = new int[N];
        for (int i = 0; i < N; i++) {
            arr[i] = sc.nextInt();
        }
        int K = sc.nextInt();
       
        // Tạo mảng quản lý K luồng
        MaxThread[] threads = new MaxThread[K];
       
        // Chia mảng thành K phần
        int baseSize = N / K;
        int remainder = N % K;
       
        int currentStart = 0;
        for (int i = 0; i < K; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);
           
            // Khởi tạo và kích hoạt luồng i
            threads[i] = new MaxThread(arr, currentStart, currentEnd);
            threads[i].start();
           
            currentStart = currentEnd;
        }
       
        // Biến lưu số lớn nhất toàn mảng
        int globalMax = Integer.MIN_VALUE;
       
        // Đợi tất cả các luồng xử lý xong và tìm max cuối cùng
        for (int i = 0; i < K; i++) {
            try {
                threads[i].join(); // Đợi luồng i chạy xong
                if (threads[i].getMaxVal() > globalMax) {
                    globalMax = threads[i].getMaxVal();
                }
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
       
        // In ra số lớn nhất
        System.out.println(globalMax);
        sc.close();
    }
}
