Đọc một dãy số nguyên không âm từ stdin, mỗi số đại diện cho 1 byte (0-255).
Ghi dãy byte đó vào file src.bin bằng FileOutputStream.
Mở src.bin bằng FileInputStream và sao chép sang dst.bin bằng FileOutputStream, sao chép theo buffer kích thước 1024 byte.
import java.io.*;
import java.util.*;


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        byte[] src = new byte[n];
        long expectedSum = 0;
        for (int i = 0; i < n; i++) {
            int v = sc.nextInt();
            src[i] = (byte) v;
            expectedSum += v;
        }


        String srcPath = "src.bin";
        String dstPath = "dst.bin";


        // 1. Ghi dãy byte ban đầu vào file src.bin bằng FileOutputStream
        try (FileOutputStream fos = new FileOutputStream(srcPath)) {
            fos.write(src);
        }


        // 2. Sao chép src.bin sang dst.bin bằng luồng Byte Stream với buffer 1024 byte
        try (FileInputStream fis = new FileInputStream(srcPath);
             FileOutputStream fos = new FileOutputStream(dstPath)) {
           
            byte[] buffer = new byte[1024];
            int bytesRead;
            // Đọc liên tục cho đến khi hàm trả về -1 (hết dữ liệu file)
            while ((bytesRead = fis.read(buffer)) != -1) {
                // Chỉ ghi đúng số lượng byte thực tế vừa đọc được từ bộ đệm vào file đích
                fos.write(buffer, 0, bytesRead);
            }
        }


        long actualSize = 0;
        long actualSum = 0;


        // 3. Đọc lại file dst.bin để tính SIZE, SUM và kiểm tra CHECKSUM
        try (FileInputStream fis = new FileInputStream(dstPath)) {
            int b;
            // Đọc tuần tự từng byte một từ file dst.bin
            while ((b = fis.read()) != -1) {
                actualSize++; // Tăng kích thước số lượng byte lọt vào file
               
                // Vì fis.read() tự động trả về giá trị unsigned (0-255) dưới dạng số int,
                // ta có thể cộng trực tiếp giá trị b này vào biến tích lũy tổng
                actualSum += b;
            }
        }


        // 4. In kết quả đầu ra theo đúng định dạng 3 dòng yêu cầu của hệ thống
        System.out.println("SIZE " + actualSize);
        System.out.println("SUM " + actualSum);
       
        if (actualSum == expectedSum) {
            System.out.println("CHECKSUM_MATCH");
        } else {
            System.out.println("MISMATCH");
        }


        sc.close();
    }
}
