import java.util.*;
import java.util.stream.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }


        // 1. Lọc và giữ lại các phần tử chẵn đưa vào mảng mới bằng IntStream
        int[] evenArr = IntStream.of(arr)
                                 .filter(x -> x % 2 == 0)
                                 .toArray();


        // 2. Tính tổng các phần tử chẵn
        long sum = IntStream.of(evenArr).sum();


        // 3. Tính trung bình các phần tử chẵn
        // Hàm .average() trả về một đối tượng OptionalDouble đề phòng mảng rỗng
