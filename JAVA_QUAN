public class Main {
    public static void main(String[] args) {


        Scanner sc = new Scanner(System.in);
        String filePath = "text.txt";


        List<String> lines = new ArrayList<>();


        // 1. Nhập nhiều dòng văn bản, dừng khi nhập dòng trống
        while (sc.hasNextLine()) {
