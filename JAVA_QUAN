        // 2. Ghi file bằng FileWriter sử dụng cú pháp try-with-resources để tự động đóng luồng
        try (FileWriter writer = new FileWriter(filePath)) {
            for (String line : lines) {
                writer.write(line);
                writer.write("\n"); // Ghi ký tự xuống dòng để phân tách các dòng văn bản
            }
            writer.flush(); // Đẩy toàn bộ dữ liệu từ bộ đệm xuống đĩa cứng
        } catch (IOException e) {
            e.printStackTrace();
        }


        // 3. Đọc file bằng BufferedReader và đếm số dòng thực tế
        int lineCount = 0;
        try (BufferedReader reader = new BufferedReader(new FileReader(filePath))) {
            String currentLine;
            // Đọc tuần tự từng dòng trong file cho đến khi hết dữ liệu (null)
            while ((currentLine = reader.readLine()) != null) {
                System.out.println(currentLine); // In nguyên vẹn dòng văn bản ra màn hình
                lineCount++;                     // Tích lũy số lượng dòng
            }
        } catch (IOException e) {
            e.printStackTrace();
        }


        // 4. Hiển thị tổng số dòng đếm được ở cuối cùng theo đúng định dạng mẫu
        System.out.println("số dòng: " + lineCount);
       
        sc.close();
    }
}

Xây dựng chương trình quản lý phương tiện giao thông theo hướng đối tượng:
a) Tạo interface ITaxable
Phương thức: double calcTax() – tính thuế phương tiện.
b) Tạo lớp trừu tượng Vehicle
import java.util.*;


// a) Tạo interface ITaxable
interface ITaxable {
    double calcTax(); // Phương thức tính thuế phương tiện
}


// b) Tạo lớp trừu tượng Vehicle
abstract class Vehicle {
    private String brand;       // Hãng xe (private)
    protected String plateNumber; // Biển số (protected)
    protected double basePrice;   // Giá cơ bản (protected)


    // Constructor đầy đủ tham số
    public Vehicle(String brand, String plateNumber, double basePrice) {
        this.brand = brand;
        this.plateNumber = plateNumber;
        this.basePrice = basePrice;
    }


    // Getter và Setter cho thuộc tính private brand
    public String getBrand() {
        return brand;
    }


    public void setBrand(String brand) {
        this.brand = brand;
    }


    // Phương thức trừu tượng hiển thị thông tin
    public abstract void showInfo();
}


// c1) Tạo lớp Car kế thừa Vehicle và triển khai ITaxable
class Car extends Vehicle implements ITaxable {
    private int seatCount;


    // Constructor đầy đủ tham số
    public Car(String brand, String plateNumber, double basePrice, int seatCount) {
        super(brand, plateNumber, basePrice); // Gọi constructor lớp cha
        this.seatCount = seatCount;
    }


    // Ghi đè tính thuế: seatCount <= 5 dùng 10%, ngược lại dùng 12%
    @Override
    public double calcTax() {
        if (seatCount <= 5) {
            return basePrice * 0.10;
        } else {
            return basePrice * 0.12;
        }
    }


    // Ghi đè phương thức hiển thị thông tin
    @Override
    public void showInfo() {
        double tax = calcTax();
        double total = basePrice + tax;
        System.out.println("=== Car ===");
        System.out.println("Hãng: " + getBrand());
        System.out.println("Biển số: " + plateNumber);
        System.out.printf("Giá cơ bản: %.2f\n", basePrice);
        System.out.println("Số ghế: " + seatCount);
        System.out.printf("Thuế: %.2f\n", tax);
        System.out.printf("Tổng tiền: %.2f\n", total);
    }
}


// c2) Tạo lớp Motorbike kế thừa Vehicle và triển khai ITaxable
class Motorbike extends Vehicle implements ITaxable {
    private int engineCC;


    // Constructor đầy đủ tham số
    public Motorbike(String brand, String plateNumber, double basePrice, int engineCC) {
        super(brand, plateNumber, basePrice); // Gọi constructor lớp cha
        this.engineCC = engineCC;
    }


    // Ghi đè tính thuế: engineCC < 150 dùng 5%, ngược lại dùng 8%
    @Override
    public double calcTax() {
        if (engineCC < 150) {
            return basePrice * 0.05;
        } else {
            return basePrice * 0.08;
        }
    }


    // Ghi đè phương thức hiển thị thông tin
    @Override
    public void showInfo() {
        double tax = calcTax();
        double total = basePrice + tax;
        System.out.println("=== Motorbike ===");
        System.out.println("Hãng: " + getBrand());
        System.out.println("Biển số: " + plateNumber);
        System.out.printf("Giá cơ bản: %.2f\n", basePrice);
        System.out.println("Dung tích: " + engineCC);
        System.out.printf("Thuế: %.2f\n", tax);
        System.out.printf("Tổng tiền: %.2f\n", total);
    }
}


public class Main {
    public static void main(String[] args) {
        Locale.setDefault(Locale.US);
        Scanner sc = new Scanner(System.in);


        // Đọc dữ liệu cho đối tượng Car (Khung code hệ thống đã cấp sẵn)
        if (!sc.hasNextLine()) return;
