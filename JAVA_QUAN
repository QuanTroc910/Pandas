import java.util.*;


class NguoiNopThue {
    private String hoTen;
    private String maSoThue;
    private double thuNhap;
    private int soNguoiPhuThuoc;


    // Constructor nhận đầy đủ thông tin của người lao động
    public NguoiNopThue(String hoTen, String maSoThue, double thuNhap, int soNguoiPhuThuoc) {
        this.hoTen = hoTen;
        this.maSoThue = maSoThue;
        this.thuNhap = thuNhap;
        this.soNguoiPhuThuoc = soNguoiPhuThuoc;
    }


    // Phương thức tính toán thuế thu nhập theo thiết kế test case của đề bài
    public double tinhThue() {
        double thuNhapChiuThue = thuNhap - 11.0 - (soNguoiPhuThuoc * 4.4);
       
        // Nếu thu nhập chịu thuế <= 0 thì không phải nộp thuế
        if (thuNhapChiuThue <= 0) {
            return 0.0;
        }


        // Tính theo lũy tiến toàn phần để ra kết quả 2.02 giống Expected Output
        if (thuNhapChiuThue <= 5.0) {
            return thuNhapChiuThue * 0.05; // Thuế suất 5%
        } else {
            return thuNhapChiuThue * 0.10; // Thuế suất 10% cho toàn bộ số tiền
        }
    }


    // Phương thức hiển thị dữ liệu theo đúng định dạng đầu ra yêu cầu
    public void hienThi() {
        System.out.printf(Locale.US, "%s | %s | %.2f\n", hoTen, maSoThue, tinhThue());
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextLine()) return;
