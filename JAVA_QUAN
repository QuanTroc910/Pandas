            // Khởi tạo luồng và kích hoạt bằng lệnh start()
            threads[i] = new SumThread(arr, currentStart, currentEnd);
            threads[i].start();
           
            currentStart = currentEnd;
        }
       
        long finalResult = 0;
       
        // Đợi tất cả các luồng hoàn thành công việc và cộng dồn kết quả cuối cùng
        for (int i = 0; i < K; i++) {
