    }
}
Đề bài 22: Cho một mảng gồm N số nguyên. Hãy sử dụng K luồng, mỗi luồng xử lý một đoạn của mảng để tính tổng các số chẵn trong đoạn đó. Sau khi tất cả các luồng hoàn thành, chương trình cộng dồn kết quả và in ra tổng cuối cùng. 

Bài làm
import java.util.*;


// 1. Định nghĩa class luồng tính tổng số chẵn kế thừa từ Thread
class EvenSumThread extends Thread {
    private int[] arr;
    private int start, end;
    private long evenSum = 0; // Bắt buộc dùng kiểu long để tránh tràn số khi cộng dồn


    // Constructor nhận đoạn mảng cần xử lý
    public EvenSumThread(int[] arr, int start, int end) {
        this.arr = arr;
        this.start = start;
        this.end = end;
    }


    // Logic duyệt và tính tổng số chẵn chạy song song
    @Override
    public void run() {
        for (int i = start; i < end; i++) {
            if (arr[i] % 2 == 0) {
                evenSum += arr[i];
            }
        }
    }


    // Hàm lấy kết quả tổng số chẵn của riêng luồng này
    public long getEvenSum() {
        return evenSum;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Nhập dữ liệu đầu vào
        if (!sc.hasNextInt()) return;
        int N = sc.nextInt();
       
        int[] arr = new int[N];
        for (int i = 0; i < N; i++) {
            arr[i] = sc.nextInt();
        }
       
        int K = sc.nextInt();
       
        // Tạo mảng quản lý K luồng
        EvenSumThread[] threads = new EvenSumThread[K];
       
        // Chia việc phân đoạn mảng đều cho K luồng
        int baseSize = N / K;
        int remainder = N % K;
       
        int currentStart = 0;
        for (int i = 0; i < K; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);
           
            // Khởi tạo luồng và kích hoạt bằng lệnh start()
            threads[i] = new EvenSumThread(arr, currentStart, currentEnd);
            threads[i].start();
           
            currentStart = currentEnd;
        }
       
        long finalResult = 0;
       
        // Đợi tất cả các luồng hoàn thành và cộng dồn kết quả
        for (int i = 0; i < K; i++) {
            try {
                threads[i].join(); // Chờ luồng i xử lý xong hoàn toàn mới lấy dữ liệu
                finalResult += threads[i].getEvenSum();
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
       
        // In ra tổng cuối cùng
        System.out.println(finalResult);
        sc.close();
    }
}

