import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        // TreeMap tự động quản lý các Key (từ) theo thứ tự tăng dần (Alphabet)
        TreeMap<String, Integer> freq = new TreeMap<>();


        // Vòng lặp đọc dữ liệu liên tục từ stdin cho đến khi gặp kết thúc file (EOF)
        while (sc.hasNextLine()) {
            String line = sc.nextLine();
           
            // Tách từ bằng khoảng trắng và các ký tự không phải chữ/số theo đề bài yêu cầu
            // [^\p{L}\p{N}]+ nghĩa là phủ định của chữ cái (Letter) và chữ số (Number) trong Unicode
            String[] words = line.split("[^\\p{L}\\p{N}]+");
           
            for (String word : words) {
                // Chuẩn hoá toàn bộ từ về dạng chữ thường
                String lowerWord = word.toLowerCase();
               
                // Điều kiện chặn: Bỏ qua các chuỗi rỗng sinh ra do ký tự đặc biệt ở đầu/cuối dòng
                if (!lowerWord.isEmpty()) {
                    // Cập nhật tần suất xuất hiện vào TreeMap
                    freq.put(lowerWord, freq.getOrDefault(lowerWord, 0) + 1);
                }
            }
        }


        // Duyệt TreeMap và in kết quả ra màn hình theo đúng định dạng
        for (Map.Entry<String, Integer> entry : freq.entrySet()) {
            System.out.println(entry.getKey() + " " + entry.getValue());
        }


        sc.close();
    }
}
