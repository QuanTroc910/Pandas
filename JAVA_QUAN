import java.io.*;
import java.util.*;


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNextLine()) return;
        int n = Integer.parseInt(sc.nextLine().trim());
        String path = "students.csv";


        // 1. Đọc dữ liệu từ bàn phím và ghi ra file students.csv theo chuẩn cấu trúc dữ liệu
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(path))) {
            // Ghi dòng tiêu đề đầu tiên (Header)
            bw.write("ma,ten,lop,diem");
            bw.newLine();
           
            // Ghi N dòng dữ liệu sinh viên
            for (int i = 0; i < n; i++) {
                bw.write(sc.nextLine().trim());
                if (i < n - 1) {
                    bw.newLine();
                }
            }
        }


        // Tạo 2 TreeMap để theo dõi tổng điểm và số lượng sinh viên của từng lớp (tự động sort alphabet)
        TreeMap<String, Double> classTotalScore = new TreeMap<>();
        TreeMap<String, Integer> classStudentCount = new TreeMap<>();


        // 2. Sử dụng BufferedReader để đọc lại file và tiến hành gom tụ dữ liệu thống kê
        try (BufferedReader br = new BufferedReader(new FileReader(path))) {
            String line;
           
            // Đọc và bỏ qua dòng đầu tiên (Header: ma,ten,lop,diem)
            br.readLine();
           
            // Đọc tuần tự từng dòng dữ liệu sinh viên còn lại
            while ((line = br.readLine()) != null) {
                if (line.trim().isEmpty()) continue;
               
                // Tách dòng thành các trường dữ liệu bằng dấu phẩy
                String[] tokens = line.split(",");
                if (tokens.length == 4) {
                    String className = tokens[2];
                    double score = Double.parseDouble(tokens[3]);
                   
                    // Cộng dồn điểm số vào lớp tương ứng
                    classTotalScore.put(className, classTotalScore.getOrDefault(className, 0.0) + score);
                    // Tăng số lượng thành viên của lớp đó lên 1
                    classStudentCount.put(className, classStudentCount.getOrDefault(className, 0) + 1);
                }
            }
        }


        // 3. Duyệt qua TreeMap (đã tự sort theo lớp) để tính điểm trung bình và in kết quả
        for (String className : classTotalScore.keySet()) {
            double totalScore = classTotalScore.get(className);
            int studentCount = classStudentCount.get(className);
            double avgScore = totalScore / studentCount;
           
            // In kết quả theo cấu trúc: <lop> <avg> làm tròn 2 chữ số thập phân
            System.out.printf("%s %.2f\n", className, avgScore);
        }


        sc.close();
    }
}
Một dịch vụ cho thuê phương tiện có 3 loại xe: Car, Bike, Truck. Mỗi loại có công thức tính phí khác nhau dựa trên số ngày thuê. 
import java.util.*;


// Lớp trừu tượng gốc Vehicle hệ thống đã khai báo sẵn
abstract class Vehicle {
    String plate;
    String model;
   
    public Vehicle(String plate, String model) {
        this.plate = plate;
        this.model = model;
    }
   
    abstract double rentalFee(int days);
}


// Lớp Car kế thừa Vehicle
class Car extends Vehicle {
    double dailyRate;


    public Car(String plate, String model, double dailyRate) {
        super(plate, model);
        this.dailyRate = dailyRate;
    }


    @Override
    double rentalFee(int days) {
        double fee = dailyRate * days;
        // Nếu số ngày thuê từ 7 ngày trở lên thì giảm giá 10%
        if (days >= 7) {
            fee *= 0.9;
        }
        return fee;
    }
}


// Lớp Bike kế thừa Vehicle
class Bike extends Vehicle {
    double dailyRate;


    public Bike(String plate, String model, double dailyRate) {
        super(plate, model);
        this.dailyRate = dailyRate;
    }


    @Override
    double rentalFee(int days) {
        // Công thức phí thuê rẻ hơn xe hơi 40% (tức là bằng 60%)
        return dailyRate * days * 0.6;
    }
}


// Lớp Truck kế thừa Vehicle
class Truck extends Vehicle {
    double dailyRate;
    double loadKg;


    public Truck(String plate, String model, double dailyRate, double loadKg) {
        super(plate, model);
        this.dailyRate = dailyRate;
        this.loadKg = loadKg;
    }


    @Override
    double rentalFee(int days) {
        // Công thức tính phí thuê gốc kèm phụ phí tải trọng
        return dailyRate * days + loadKg * 50;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào tránh lỗi hệ thống OJ khi quét file trống
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        // Sử dụng HashMap để quản lý xe theo biển số nhằm tối ưu hóa tốc độ tìm kiếm O(1)
        Map<String, Vehicle> fleet = new HashMap<>();
       
        for (int i = 0; i < n; i++) {
            String type = sc.next();
            String plate = sc.next();
            String model = sc.next();
            double dailyRate = sc.nextDouble();
           
            if (type.equals("CAR")) {
                fleet.put(plate, new Car(plate, model, dailyRate));
            } else if (type.equals("BIKE")) {
                fleet.put(plate, new Bike(plate, model, dailyRate));
            } else if (type.equals("TRUCK")) {
                double loadKg = sc.nextDouble(); // Đọc thêm trường loadKg đặc trưng của TRUCK
                fleet.put(plate, new Truck(plate, model, dailyRate, loadKg));
            }
        }
       
        if (!sc.hasNextInt()) return;
        int m = sc.nextInt();
       
        double totalFee = 0; // Biến tích lũy tổng doanh thu thuê xe toàn hệ thống
       
        // Xử lý M lệnh thuê xe
        for (int i = 0; i < m; i++) {
            String plate = sc.next();
            int days = sc.nextInt();
           
            // Tìm kiếm nhanh phương tiện theo biển số trong HashMap
            Vehicle v = fleet.get(plate);
            if (v != null) {
                // Tính toán đa hình tùy thuộc vào kiểu đối tượng thực tế (Car, Bike hay Truck)
                double fee = v.rentalFee(days);
                totalFee += fee;
               
                // In ra chi phí của lệnh thuê hiện tại làm tròn 2 chữ số thập phân
                System.out.printf("%s %.2f\n", plate, fee);
            }
        }
       
        // In dòng tổng kết cuối cùng
        System.out.printf("TOTAL %.2f\n", totalFee);
       
        sc.close();
    }
}
