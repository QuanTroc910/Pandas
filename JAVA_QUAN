Cho danh sách N số nguyên và số K. Hãy in ra các giá trị xuất hiện ≥ K lần trong danh sách, sắp xếp tăng dần.
Nếu không có giá trị nào thỏa mãn, in NONE.
Đếm bằng HashMap<Integer, Integer>.
Lọc và sắp xếp bằng TreeSet<Integer> hoặc ArrayList + Collections.sort.
import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp test case trống
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        int k = sc.nextInt();
       
        HashMap<Integer, Integer> cnt = new HashMap<>();
       
        // 1. Duyệt qua N số nguyên để đếm tần suất xuất hiện bằng HashMap
        for (int i = 0; i < n; i++) {
            int num = sc.nextInt();
            // Nếu số đã tồn tại thì tăng số đếm lên 1, ngược lại đặt mặc định là 0 rồi cộng 1
            cnt.put(num, cnt.getOrDefault(num, 0) + 1);
        }


        // 2. Sử dụng TreeSet để lọc phần tử xuất hiện >= K lần và tự động sắp xếp tăng dần
        TreeSet<Integer> result = new TreeSet<>();
        for (Map.Entry<Integer, Integer> entry : cnt.entrySet()) {
            if (entry.getValue() >= k) {
                result.add(entry.getKey());
            }
        }


        // 3. Xử lý in kết quả đầu ra theo đúng định dạng khuôn mẫu
        if (result.isEmpty()) {
            System.out.println("NONE");
        } else {
            StringBuilder sb = new StringBuilder();
            for (int num : result) {
                sb.append(num).append(" ");
            }
            // In chuỗi và cắt bỏ khoảng trắng thừa ở cuối cùng
            System.out.println(sb.toString().trim());
        }
       
        sc.close();
    }
}
