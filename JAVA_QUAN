import java.io.*;
import java.util.*;


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
        String path = "data.txt";


        // 1. Đọc từ bàn phím cho đến khi gặp EOF và ghi vào file bằng FileWriter
        // Sử dụng try-with-resources để tự động đóng luồng và đẩy dữ liệu xuống đĩa
        try (FileWriter fw = new FileWriter(path)) {
            while (sc.hasNextLine()) {
                fw.write(sc.nextLine());
                if (sc.hasNextLine()) {
                    fw.write("\n"); // Ghi dấu xuống dòng nếu vẫn còn dòng tiếp theo
                }
            }
        }


        int lines = 0;
        int words = 0;
        int chars = 0;


        // 2. Đọc lại file bằng BufferedReader để phân tích và đếm dữ liệu
        try (BufferedReader br = new BufferedReader(new FileReader(path))) {
            String line;
            while ((line = br.readLine()) != null) {
                lines++; // Tăng số dòng lên 1
               
                chars += line.length(); // Số ký tự trong dòng (không tính ký tự xuống dòng)
               
                // Logic đếm từ chuẩn xác: Loại bỏ khoảng trắng rìa và tách theo cụm khoảng trắng giữa
                String trimmedLine = line.trim();
                if (!trimmedLine.isEmpty()) {
                    String[] tokens = trimmedLine.split("\\s+");
                    words += tokens.length;
                }
            }
        }


        // 3. In kết quả đầu ra theo đúng định dạng yêu cầu của hệ thống
        System.out.println("lines: " + lines);
        System.out.println("words: " + words);
        System.out.println("chars: " + chars);


        sc.close();
    }
}
