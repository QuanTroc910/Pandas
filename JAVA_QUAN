Đề bài 8 :Cho danh sách tên sinh viên và điểm số. Dùng HashMap<String, Integer> để lưu dữ liệu. Sau đó đưa tên sinh viên vào TreeSet, dùng comparator dựa trên điểm số để sắp xếp giảm dần. Nếu cùng điểm → sắp xếp theo tên.
In ra danh sách xếp hạng

import java.util.Scanner;
import java.util.HashMap;
import java.util.TreeSet;
import java.util.Comparator;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int N = sc.nextInt();
       
        // 1. Dùng HashMap để lưu dữ liệu <Tên, Điểm>
        HashMap<String, Integer> map = new HashMap<>();
        for (int i = 0; i < N; i++) {
            String ten = sc.next();
            int diem = sc.nextInt();
            map.put(ten, diem);
        }
       
        // 2. Định nghĩa bộ Comparator tùy biến dựa trên quy tắc đề bài
        Comparator<String> customComparator = new Comparator<String>() {
            @Override
            public int compare(String s1, String s2) {
                int diem1 = map.get(s1);
                int diem2 = map.get(s2);
               
                // Điều kiện 1: Sắp xếp điểm số GIẢM DẦN
                if (diem1 != diem2) {
                    return Integer.compare(diem2, diem1); // đảo s2 lên trước s1 để giảm dần
                }
               
                // Điều kiện 2: Nếu cùng điểm số -> sắp xếp tăng dần theo tên
                return s1.compareTo(s2);
            }
        };
       
        // 3. Đưa tên sinh viên vào TreeSet đi kèm bộ Comparator vừa viết
        TreeSet<String> xepHangSet = new TreeSet<>(customComparator);
        // Nạp toàn bộ danh sách tên (keySet) từ Map vào TreeSet để nó tự động sắp xếp
        xepHangSet.addAll(map.keySet());
       
        // 4. In ra danh sách xếp hạng theo định dạng <ten>: <diem>
        for (String ten : xepHangSet) {
            System.out.println(ten + ": " + map.get(ten));
        }
       
        sc.close();
    }
}
Đề bài 9:Cho mảng N số nguyên lớn. Dùng K luồng, mỗi luồng xử lý một đoạn của mảng và đếm xem có bao nhiêu số nguyên tố. Cuối cùng cộng dồn số lượng lại. 

Bài làm:
import java.util.*;


// 1. Định nghĩa class luồng đếm số nguyên tố kế thừa từ Thread
class PrimeThread extends Thread {
    private int[] arr;
    private int start, end;
    private int count = 0; // Lưu số lượng số nguyên tố đếm được của đoạn này


    // Constructor để nạp dữ liệu đoạn mảng cho luồng
    public PrimeThread(int[] arr, int start, int end) {
        this.arr = arr;
        this.start = start;
        this.end = end;
    }


    // Hàm kiểm tra số nguyên tố tối ưu
    private boolean isPrime(int n) {
        if (n <= 1) return false;
        if (n <= 3) return true;
        if (n % 2 == 0 || n % 3 == 0) return false;
       
        // Kiểm tra các số có dạng 6k +/- 1 để chạy nhanh hơn
        for (int i = 5; i * i <= n; i += 6) {
            if (n % i == 0 || n % (i + 2) == 0) return false;
        }
        return true;
    }


    // Logic duyệt đoạn mảng được giao để đếm số nguyên tố
    @Override
    public void run() {
        for (int i = start; i < end; i++) {
            if (isPrime(arr[i])) {
                count++;
            }
        }
    }


    // Hàm phụ để hàm main lấy kết quả đếm của luồng này
    public int getCount() {
        return count;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        int N = sc.nextInt();
        int[] arr = new int[N];
        for (int i = 0; i < N; i++) {
            arr[i] = sc.nextInt();
        }
        int K = sc.nextInt();
       
        // Tạo mảng quản lý K luồng
        PrimeThread[] threads = new PrimeThread[K];
       
        // Chia việc phân đoạn mảng cho K luồng
        int baseSize = N / K;
        int remainder = N % K;
       
        int currentStart = 0;
        for (int i = 0; i < K; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);
           
            // Khởi tạo và kích hoạt luồng i
            threads[i] = new PrimeThread(arr, currentStart, currentEnd);
            threads[i].start();
           
            currentStart = currentEnd;
        }
       
        int totalPrimes = 0;
       
        // Đợi tất cả các luồng hoàn thành và cộng dồn số lượng
        for (int i = 0; i < K; i++) {
            try {
                threads[i].join(); // Chờ luồng i xử lý xong
                totalPrimes += threads[i].getCount();
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
       
        // In ra tổng số lượng số nguyên tố đếm được toàn mảng
        System.out.println(totalPrimes);
        sc.close();
    }
}
Đề bài 10:Cho mảng gồm N số nguyên lớn. Dùng K luồng, mỗi luồng tính tổng bình phương một đoạn của mảng. Cuối cùng cộng dồn kết quả và in ra tổng cuối cùng. 

Bài làm:
import java.util.*;


// 1. Định nghĩa class luồng tính tổng bình phương kế thừa từ Thread
class SquareThread extends Thread {
    private int[] arr;
    private int start, end;
    private long totalSum = 0; // Dùng kiểu long để tránh tràn số khi cộng dồn bình phương


    // Constructor nạp đoạn mảng cần xử lý cho luồng
    public SquareThread(int[] arr, int start, int end) {
        this.arr = arr;
        this.start = start;
        this.end = end;
    }


    // Logic tính tổng bình phương của đoạn mảng chạy song song
    @Override
    public void run() {
        for (int i = start; i < end; i++) {
            // Ép kiểu sang long trước khi nhân bình phương để tránh tràn số cục bộ
            long val = arr[i];
            totalSum += val * val;
        }
    }


    // Hàm phụ để lấy kết quả từ luồng này sau khi chạy xong
    public long getTotalSum() {
        return totalSum;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        int N = sc.nextInt();
        int[] arr = new int[N];
        for (int i = 0; i < N; i++) {
            arr[i] = sc.nextInt();
        }
        int K = sc.nextInt();
       
        // Tạo mảng quản lý K luồng
        SquareThread[] threads = new SquareThread[K];
       
        // Chia việc phân đoạn mảng cho K luồng
        int baseSize = N / K;
        int remainder = N % K;
       
        int currentStart = 0;
        for (int i = 0; i < K; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);
           
            // Khởi tạo và kích hoạt luồng i
            threads[i] = new SquareThread(arr, currentStart, currentEnd);
            threads[i].start();
           
            currentStart = currentEnd;
        }
       
        long finalResult = 0;
       
        // Đợi tất cả các luồng hoàn thành và thu hoạch kết quả cộng dồn
        for (int i = 0; i < K; i++) {
            try {
                threads[i].join(); // Chờ luồng i xử lý xong hoàn toàn
                finalResult += threads[i].getTotalSum();
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
       
        // In ra tổng bình phương cuối cùng
        System.out.println(finalResult);
        sc.close();
    }
}
Đề bài 11:Cho một danh sách số nguyên trong ArrayList. Hãy sử dụng HashMap để đếm số lần xuất hiện của mỗi phần tử và in ra theo thứ tự xuất hiện lần đầu. 

Bài làm 
import java.util.Scanner;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.Map;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int N = sc.nextInt();
       
        // 1. Lưu danh sách số nguyên vào ArrayList theo yêu cầu đề bài
        ArrayList<Integer> list = new ArrayList<>();
       
        // 2. Dùng LinkedHashMap để đếm tần suất VÀ giữ nguyên thứ tự xuất hiện lần đầu
        LinkedHashMap<Integer, Integer> countMap = new LinkedHashMap<>();
       
        for (int i = 0; i < N; i++) {
            int num = sc.nextInt();
            list.add(num); // Thêm vào ArrayList
           
            // Đếm số lần xuất hiện
            countMap.put(num, countMap.getOrDefault(num, 0) + 1);
        }
       
        // 3. Duyệt qua LinkedHashMap để in kết quả theo đúng thứ tự xuất hiện đầu tiên
        // Định dạng yêu cầu: <giá trị>: <số lần>
        for (Map.Entry<Integer, Integer> entry : countMap.entrySet()) {
            System.out.println(entry.getKey() + ": " + entry.getValue());
        }
       
        sc.close();
    }
}
