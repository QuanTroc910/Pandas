Cho danh sách N học sinh. Mỗi học sinh có name (String) và score (double). Cần tìm K học sinh có điểm cao nhất trong khi chỉ giữ tối đa K phần tử trong PriorityQueue ở mọi thời điểm (để tối ưu bộ nhớ khi N rất lớn). 

import java.util.*;


// Định nghĩa lớp Student để quản lý dữ liệu học sinh
class Student {
    String name;
    double score;


    public Student(String name, double score) {
        this.name = name;
        this.score = score;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng test case trống từ hệ thống OJ
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        int k = sc.nextInt();
       
        // Cấu hình Min-Heap cho PriorityQueue để tối ưu giữ tối đa K phần tử
        PriorityQueue<Student> pq = new PriorityQueue<>(new Comparator<Student>() {
            @Override
            public int compare(Student s1, Student s2) {
                if (Double.compare(s1.score, s2.score) != 0) {
                    // Điểm thấp hơn đứng trước để bị poll() loại bỏ trước
                    return Double.compare(s1.score, s2.score);
                }
                // Nếu điểm bằng nhau, tên theo alphabet lớn hơn (đứng sau)
                // sẽ đứng trước trong hàng đợi để bị loại bỏ trước
                return s2.name.compareTo(s1.name);
            }
        });


        // Duyệt qua từng học sinh và xử lý stream dữ liệu trực tiếp
        for (int i = 0; i < n; i++) {
            String name = sc.next();
            double score = sc.nextDouble();
           
            pq.offer(new Student(name, score));
           
            // Nếu vượt quá K phần tử, lập tức loại bỏ phần tử "vô địch từ dưới lên"
            if (pq.size() > k) {
                pq.poll();
            }
        }


        // Bốc các phần tử còn sót lại trong PriorityQueue ra một danh sách để sắp xếp đầu ra
        List<Student> result = new ArrayList<>();
        while (!pq.isEmpty()) {
            result.add(pq.poll());
        }


        // Sắp xếp danh sách kết quả theo yêu cầu: điểm giảm dần, điểm bằng nhau alphabet tăng dần
        Collections.sort(result, new Comparator<Student>() {
            @Override
            public int compare(Student s1, Student s2) {
                if (Double.compare(s1.score, s2.score) != 0) {
                    return Double.compare(s2.score, s1.score); // Điểm giảm dần
                }
                return s1.name.compareTo(s2.name); // Tên tăng dần
            }
        });


        // In ra K học sinh điểm cao nhất theo đúng định dạng mẫu
        for (Student s : result) {
            System.out.printf("%s %.2f\n", s.name, s.score);
        }


        sc.close();
    }
}
