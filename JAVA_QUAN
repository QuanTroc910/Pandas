        // Sử dụng Stream API để lọc và tìm kiếm chuỗi đầu tiên thỏa mãn điều kiện
        String result = list.stream()
                            .filter(s -> s.startsWith(prefix))
                            .findFirst()
                            .orElse("NOT_FOUND");


