        System.out.println("Others: " + othersCount);


        sc.close();
    }
}
Cho hai ArrayList<Integer> A và B đã được sắp xếp tăng dần. Hãy trộn chúng thành một danh sách C cũng tăng dần mà không sort lại toàn bộ — sử dụng kỹ thuật hai con trỏ (two-pointer) duyệt qua hai danh sách. 

import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // 1. Đọc dữ liệu danh sách A (Khung code hệ thống đã cấp sẵn)
        if (!sc.hasNextInt()) return;
        int nA = sc.nextInt();
        ArrayList<Integer> a = new ArrayList<>();
        for (int i = 0; i < nA; i++) a.add(sc.nextInt());
       
        // 2. Đọc dữ liệu danh sách B (Khung code hệ thống đã cấp sẵn)
        int nB = sc.nextInt();
        ArrayList<Integer> b = new ArrayList<>();
        for (int i = 0; i < nB; i++) b.add(sc.nextInt());
       
        // Khởi tạo danh sách kết quả C và hai con trỏ i, j
        ArrayList<Integer> c = new ArrayList<>(nA + nB);
        int i = 0; // Con trỏ chạy trên danh sách a
        int j = 0; // Con trỏ chạy trên danh sách b


        // 3. Kỹ thuật hai con trỏ (two-pointer merge)
        // Vòng lặp chạy khi cả hai con trỏ đều chưa vượt quá biên danh sách tương ứng
        while (i < nA && j < nB) {
            if (a.get(i) <= b.get(j)) {
                c.add(a.get(i));
                i++; // Dịch con trỏ i lên sau khi lấy phần tử ở danh sách a
            } else {
                c.add(b.get(j));
                j++; // Dịch con trỏ j lên sau khi lấy phần tử ở danh sách b
            }
        }


        // 4. Nối phần còn sót lại của danh sách A (nếu có)
        while (i < nA) {
            c.add(a.get(i));
            i++;
        }


        // 5. Nối phần còn sót lại của danh sách B (nếu có)
        while (j < nB) {
            c.add(b.get(j));
            j++;
        }


        // 6. In toàn bộ danh sách kết quả C ra màn hình trên một dòng
        StringBuilder sb = new StringBuilder();
        for (int num : c) {
            sb.append(num).append(" ");
        }
       
        // In ra chuỗi kết quả và loại bỏ khoảng trắng dư thừa ở cuối cùng
        System.out.println(sb.toString().trim());
       
        sc.close();
    }
}

Viết chương trình thực hiện các yêu cầu sau:
Tạo lớp MyObject gồm:
Thuộc tính message (String)
Thuộc tính value (int)
Constructor đầy đủ tham số
Ghi đè phương thức toString() trả về chuỗi theo mẫu: MyObject{message='<message>', value=<value>}
Lớp MyObject phải implement Serializable để cho phép tuần tự hóa (serialization).
import java.io.*;
import java.util.*;


// Định nghĩa lớp MyObject bắt buộc phải hiện thực giao diện Serializable
class MyObject implements Serializable {
    // Thuộc tính để xác định phiên bản cấu trúc lớp khi truyền luồng byte (Khuyên dùng trong Serialization)
    private static final long serialVersionUID = 1L;
   
    String message;
    int value;


    // Constructor đầy đủ tham số
    public MyObject(String message, int value) {
        this.message = message;
        this.value = value;
    }


    // Ghi đè phương thức toString() trả về chuỗi chính xác theo khuôn mẫu đề bài
    @Override
    public String toString() {
        return "MyObject{message='" + message + "', value=" + value + "}";
    }
}


public class Main {
    public static void main(String[] args) {


        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào tránh lỗi quét dữ liệu rỗng hệ thống OJ
        if (!sc.hasNextLine()) return;
        String message = sc.nextLine();
        int value = sc.nextInt();


        // Khởi tạo đối tượng dựa trên dữ liệu vừa đọc từ bàn phím
        MyObject obj = new MyObject(message, value);
        String filePath = "object.txt";


        // 1. Ghi đối tượng vào file object.txt bằng ObjectOutputStream
        try (ObjectOutputStream oos = new ObjectOutputStream(new FileOutputStream(filePath))) {
            oos.writeObject(obj); // Tuần tự hóa: Biến đổi đối tượng thành chuỗi byte nhị phân ghi xuống file
            oos.flush();
        } catch (IOException e) {
            e.printStackTrace();
        }


        // 2. Đọc đối tượng từ file object.txt bằng ObjectInputStream
        try (ObjectInputStream ois = new ObjectInputStream(new FileInputStream(filePath))) {
            // Giải tuần tự hóa: Đọc chuỗi byte nhị phân và ép kiểu ngược lại thành lớp đối tượng gốc
            MyObject readObj = (MyObject) ois.readObject();
           
            // 3. Hiển thị đối tượng ra màn hình (Java sẽ tự động kích hoạt phương thức toString() của đối tượng)
            System.out.println(readObj);
        } catch (IOException | ClassNotFoundException e) {
            e.printStackTrace();
        }


        sc.close();
    }
}




