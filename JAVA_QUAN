import java.io.FileOutputStream;
import java.io.FileInputStream;
import java.io.IOException;
import java.util.Scanner;


public class Main {
    public static void main(String[] args) {


        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào tránh lỗi hệ thống OJ khi quét test rỗng
        if (!sc.hasNextLine()) return;
        String data = sc.nextLine();  
        String filePath = "raw.txt";


        // 1. Ghi chuỗi vào file raw.txt bằng FileOutputStream dưới dạng mảng byte
        try (FileOutputStream fos = new FileOutputStream(filePath)) {
            byte[] bytesToWrite = data.getBytes();
            fos.write(bytesToWrite);
        } catch (IOException e) {
            e.printStackTrace();
        }


        // Biến lưu trữ chuỗi đọc được từ file để xử lý tiếp
        String fileContent = "";


        // 2. Đọc chuỗi từ file raw.txt bằng FileInputStream
        try (FileInputStream fis = new FileInputStream(filePath)) {
            // Khởi tạo mảng byte có kích thước bằng số byte thực tế đang có trong file
            byte[] bytesToRead = new byte[fis.available()];
            fis.read(bytesToRead);
            // Chuyển mảng byte vừa bốc được ngược lại thành chuỗi String
            fileContent = new String(bytesToRead);
        } catch (IOException e) {
            e.printStackTrace();
        }


        // Sử dụng StringBuilder để thực hiện thay đổi ký tự tại chỗ một cách tối ưu bộ nhớ
        StringBuilder result = new StringBuilder();


        // 3. Xử lý chữ cái theo vị trí từ chỉ số 0 -> length - 1
        for (int i = 0; i < fileContent.length(); i++) {
            char c = fileContent.charAt(i);
           
            // Nếu chỉ số i là số lẻ, thực hiện chuyển đổi sang chữ hoa
            if (i % 2 != 0) {
                result.append(Character.toUpperCase(c));
            } else {
                // Nếu chỉ số i là số chẵn, giữ nguyên ký tự gốc ban đầu
                result.append(c);
            }
        }


        // 4. In kết quả chuỗi hoàn chỉnh sau khi xử lý ra màn hình
        System.out.println(result.toString());
       
        sc.close();
    }
}
Cho danh sách giao dịch của khách hàng với số tiền chi tiêu. Hãy xử lý dữ liệu bằng Predicate, Function, Operator, Consumer:
Dùng Predicate để giữ lại các giao dịch có giá trị ≥ 100.000.
Dùng Function để chuyển giao dịch thành chuỗi dạng "Tên: số_tiền".
import java.util.*;
import java.util.function.*;
import java.util.stream.*;


class Transaction {
    String name;
    double amount;


    Transaction(String name, double amount) {
        this.name = name;
        this.amount = amount;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextLine()) return;
        int N = Integer.parseInt(sc.nextLine().trim());


        List<Transaction> list = new ArrayList<>();
        for (int i = 0; i < N; i++) {
            String[] p = sc.nextLine().split(" ");
            list.add(new Transaction(p[0], Double.parseDouble(p[1])));
        }
       
        // 1. Khai báo Predicate: Giữ lại giao dịch có giá trị >= 100.000
        Predicate<Transaction> predicate = t -> t.amount >= 100000;


        // 2. Khai báo Function: Chuyển giao dịch thành chuỗi dạng "Tên: số_tiền" (lấy 2 chữ số thập phân)
        // Lưu ý dùng Locale.US để tránh lỗi dấu phẩy thập phân tùy thuộc cấu hình máy chủ OJ
        String formatSpec = "%.2f";
        Function<Transaction, String> mapper =
            t -> t.name + ": " + String.format(Locale.US, formatSpec, t.amount);


        // 3. Khai báo BinaryOperator: Chọn chuỗi có số tiền lớn hơn khi xảy ra trùng tên (trùng Key)
        BinaryOperator<String> operator = (s1, s2) -> {
            double v1 = Double.parseDouble(s1.split(": ")[1]);
            double v2 = Double.parseDouble(s2.split(": ")[1]);
            return v1 >= v2 ? s1 : s2;
        };


        // 4. Khai báo Consumer: In chuỗi kết quả ra màn hình (stdout)
        Consumer<String> consumer = System.out::println;


        // --- Sử dụng các đối tượng trên để xử lý dữ liệu qua Stream pipeline ---
        Map<String, String> resultMap = list.stream()
                .filter(predicate) // Bước 1: Lọc dữ liệu bằng Predicate
                // Thu gom dữ liệu vào LinkedHashMap để giữ nguyên thứ tự xuất hiện
                .collect(Collectors.toMap(
                        t -> t.name,               // Key của Map là Tên khách hàng
                        mapper,                    // Value của Map là chuỗi tạo từ Function
                        operator,                  // Giải quyết xung đột bằng BinaryOperator (giữ giao dịch lớn hơn)
                        LinkedHashMap::new         // Khởi tạo LinkedHashMap để giữ đúng thứ tự xuất hiện
                ));


        // Bước 5: Duyệt các Value trong Map để thực thi Consumer in ra màn hình
        resultMap.values().forEach(consumer);


        sc.close();
    }
}

