Cho mảng N số nguyên a[0..N-1] và số nguyên X. Hãy đếm số cặp chỉ số (i, j) với i < j sao cho a[i] + a[j] == X.
Sử dụng HashMap<Integer, Integer> để đếm tần suất các giá trị đã duyệt.
Với mỗi a[j], cộng vào kết quả số lần X - a[j] đã xuất hiện ở các chỉ số trước.
import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra chốt chặn an toàn đầu vào rỗng
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        long x = sc.nextLong();
       
        long ans = 0; // Biến lưu số cặp, dùng kiểu long để tránh tràn số (Overflow)
        HashMap<Long, Integer> seen = new HashMap<>();
       
        for (int i = 0; i < n; i++) {
            long current = sc.nextLong();
            long target = x - current; // Giá trị cần tìm để tạo thành tổng X
           
            // 1. Nếu giá trị target đã từng xuất hiện trước đó, cộng tần suất của nó vào ans
            if (seen.containsKey(target)) {
                ans += seen.get(target);
            }
           
            // 2. Cập nhật tần suất xuất hiện của phần tử hiện tại vào HashMap
            seen.put(current, seen.getOrDefault(current, 0) + 1);
        }
       
        // In ra tổng số cặp đếm được
        System.out.println(ans);
       
        sc.close();
    }
}
