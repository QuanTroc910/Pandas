import java.io.*;
import java.nio.charset.StandardCharsets;
import java.util.Scanner;


public class Main {
    public static void main(String[] args) {


        Scanner sc = new Scanner(System.in);
        String filePath = "utf8.txt";
       
        // Đọc tên tiếng Việt nhập vào từ bàn phím
        String fullName = sc.nextLine();


        // a. Ghi dữ liệu ra file bằng BufferedWriter định dạng mã hóa UTF-8
        try (BufferedWriter bw = new BufferedWriter(
                new OutputStreamWriter(new FileOutputStream(filePath), StandardCharsets.UTF_8))) {
            bw.write(fullName);
        } catch (IOException e) {
            e.printStackTrace();
        }


        // b. Đọc file bằng BufferedReader và xử lý viết hoa phần họ
        try (BufferedReader br = new BufferedReader(
                new InputStreamReader(new FileInputStream(filePath), StandardCharsets.UTF_8))) {
           
            String line = br.readLine();
            if (line != null && !line.trim().isEmpty()) {
                // Tách chuỗi theo khoảng trắng để tìm từ đầu tiên (Họ)
                String[] words = line.trim().split("\\s+");
               
                if (words.length > 0) {
                    // Chuyển phần họ thành chữ hoa
                    words[0] = words[0].toUpperCase();
                   
                    // Ghép các từ lại với nhau cách nhau bởi dấu cách
                    StringBuilder result = new StringBuilder();
                    for (int i = 0; i < words.length; i++) {
                        result.append(words[i]);
                        if (i < words.length - 1) {
                            result.append(" ");
                        }
                    }
                   
                    // In kết quả ra màn hình
                    System.out.println(result.toString());
                }
            }
           
        } catch (IOException e) {
            e.printStackTrace();
        }


        sc.close();
    }
}
