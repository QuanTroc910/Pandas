    Student(String id, String name, double gpa) {
        this.id = id;
        this.name = name;
        this.gpa = gpa;
        count++; // Tăng biến đếm tổng static lên 1
    }


    // Phương thức static trả về số lượng sinh viên hiện tại
    static int getCount() {
        return count;
    }
}


