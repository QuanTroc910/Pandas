Đề bài 13: Nhập chuỗi ký tự. Sử dụng LinkedList<Character> để lưu từng ký tự. Dùng TreeMap<Character, Integer> để đếm số lần xuất hiện và tự động sắp xếp theo alphabet. 

Bài làm:
import java.util.Scanner;
import java.util.LinkedList;
import java.util.TreeMap;
import java.util.Map;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNext()) return;
        // Đọc chuỗi ký tự đầu vào
        String input = sc.next();
       
        // 1. Sử dụng LinkedList<Character> để lưu từng ký tự theo yêu cầu đề bài
        LinkedList<Character> charList = new LinkedList<>();
        for (int i = 0; i < input.length(); i++) {
            charList.add(input.charAt(i));
        }
       
        // 2. Dùng TreeMap<Character, Integer> để đếm số lần xuất hiện và tự động sắp xếp
        TreeMap<Character, Integer> countMap = new TreeMap<>();
        for (char c : charList) {
            // Nếu ký tự đã có trong map thì tăng biến đếm, chưa có thì gán mặc định là 0 rồi + 1
            countMap.put(c, countMap.getOrDefault(c, 0) + 1);
        }
       
        // 3. Định dạng đầu ra: Mỗi dòng là `<ký tự>: <số lần>`
        for (Map.Entry<Character, Integer> entry : countMap.entrySet()) {
            System.out.println(entry.getKey() + ": " + entry.getValue());
        }
       
        sc.close();
    }
}

Đề bài 14 : Hãy tạo lớp Student (tên, tuổi, điểm). Tạo một lớp quản lý sử dụng ArrayList<Student> để:
Thêm N sinh viên từ bàn phím
Tìm sinh viên có điểm cao nhất
In ra thông tin sinh viên điểm cao nhất
Bài làm:
import java.util.Scanner;
import java.util.ArrayList;


// 1. Định nghĩa lớp Student với 3 thuộc tính: tên, tuổi, điểm
class Student {
    private String name;
    private int age;
    private double score;


    // Hàm khởi tạo (Constructor) để gán dữ liệu
    public Student(String name, int age, double score) {
        this.name = name;
        this.age = age;
        this.score = score;
    }


    // Các hàm getter để lấy dữ liệu ra so sánh và in ấn
    public String getName() {
        return name;
    }


    public int getAge() {
        return age;
    }


    public double getScore() {
        return score;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int N = sc.nextInt();
       
        // 2. Sử dụng ArrayList<Student> (Generics) để quản lý danh sách sinh viên
        ArrayList<Student> listStudent = new ArrayList<>();
       
        // Vòng lặp thêm N sinh viên từ bàn phím
        for (int i = 0; i < N; i++) {
            String name = sc.next();
            int age = sc.nextInt();
            double score = sc.nextDouble();
           
            // Tạo đối tượng Student mới và nạp vào danh sách
            listStudent.add(new Student(name, age, score));
        }
       
        // 3. Tìm sinh viên có điểm cao nhất
        // Giả định sinh viên đầu tiên (vị trí số 0) có điểm cao nhất
        Student maxStudent = listStudent.get(0);
       
        // Duyệt từ sinh viên thứ hai trở đi để tìm người có điểm thực sự cao hơn
        for (int i = 1; i < listStudent.size(); i++) {
            if (listStudent.get(i).getScore() > maxStudent.getScore()) {
                maxStudent = listStudent.get(i); // Cập nhật lại người giữ kỷ lục điểm cao
            }
        }
       
        // 4. In ra thông tin sinh viên điểm cao nhất theo đúng định dạng đầu ra
        System.out.println("Name: " + maxStudent.getName());
        System.out.println("Age: " + maxStudent.getAge());
       
        // Nếu điểm là số nguyên (ví dụ 9.0) hệ thống có thể muốn in dạng 9.0 hoặc 9
        // Lệnh in thông thường dưới đây sẽ giữ nguyên định dạng nhập vào của số thực
        System.out.printf("Score: %.2f\n", maxStudent.getScore());
       
        sc.close();
    }
}
Đề bài 15:Cho hai tập số nguyên:
Tập A lưu bằng HashSet
Tập B lưu bằng TreeSet
Hãy tìm giao của A và B, sau đó in ra theo thứ tự tăng dần.
Bài làm:
import java.util.Scanner;
import java.util.HashSet;
import java.util.TreeSet;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // 1. Nhập tập hợp A (Lưu bằng HashSet)
        if (!sc.hasNextInt()) return;
        int N = sc.nextInt();
        HashSet<Integer> setA = new HashSet<>();
        for (int i = 0; i < N; i++) {
            setA.add(sc.nextInt());
        }
       
        // 2. Nhập tập hợp B (Lưu bằng TreeSet)
        if (!sc.hasNextInt()) return;
        int M = sc.nextInt();
        TreeSet<Integer> setB = new TreeSet<>();
        for (int i = 0; i < M; i++) {
            setB.add(sc.nextInt());
        }
       
        // 3. Tìm giao của A và B bằng cách giữ lại các phần tử chung trong setA
        setA.retainAll(setB);
       
        // 4. Đổ kết quả giao vào một TreeSet mới để tự động sắp xếp tăng dần khi in
        TreeSet<Integer> result = new TreeSet<>(setA);
       
        // 5. In các phần tử chung cách nhau bởi dấu cách
        boolean first = true;
        for (int num : result) {
            if (!first) {
                System.out.print(" ");
            }
            System.out.print(num);
            first = false;
        }
        System.out.println(); // Xuống dòng khi kết thúc
       
        sc.close();
    }
}

