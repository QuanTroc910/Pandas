            String title = sc.next();
            String author = sc.next();
            double price = sc.nextDouble();
           
            // Ép kiểu đa hình dựa trên từ khóa loại sách
            if (type.equals("PAPER")) {
                library.add(new PaperBook(title, author, price));
            } else if (type.equals("EBOOK")) {
                library.add(new EBook(title, author, price));
            }
        }
       
        double totalAmount = 0;
       
        // Duyệt danh sách để in thông tin từng cuốn và cộng dồn tổng tiền
        for (Book book : library) {
            double currentFinalPrice = book.finalPrice();
            System.out.printf("%s %.2f\n", book.title, currentFinalPrice);
            totalAmount += currentFinalPrice;
        }
       
        // In dòng tổng tiền cuối cùng đúng định dạng mẫu
        System.out.printf("TOTAL %.2f\n", totalAmount);
       
        sc.close();
    }
}

Đề bài: Cho hai danh sách số nguyên A và B (có thể trùng phần tử trong mỗi danh sách).
In ra tập hợp (set) A ∪ B đã sắp xếp tăng dần.
In ra A ∩ B đã sắp xếp tăng dần.
Sử dụng HashSet để loại trùng, TreeSet hoặc sort sau khi gom để in tăng dần.
Bài làm 
import java.util.*;


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);


        // 1. Nhập danh sách A và đổ vào TreeSet để tự loại trùng + sắp xếp
        if (!sc.hasNextInt()) return;
        int nA = sc.nextInt();
        TreeSet<Integer> setA = new TreeSet<>();
        for (int i = 0; i < nA; i++) {
            setA.add(sc.nextInt());
        }


        // 2. Nhập danh sách B và đổ vào TreeSet tương tự
        if (!sc.hasNextInt()) return;
        int nB = sc.nextInt();
        TreeSet<Integer> setB = new TreeSet<>();
        for (int i = 0; i < nB; i++) {
            setB.add(sc.nextInt());
        }


        // 3. Tính Phép Hợp (UNION) = A ∪ B
        // Tạo một tập hợp mới chứa toàn bộ phần tử của setA, sau đó thêm setB vào
        TreeSet<Integer> unionSet = new TreeSet<>(setA);
        unionSet.addAll(setB);


        // 4. Tính Phép Giao (INTERSECT) = A ∩ B
        // Tạo một tập hợp mới chứa toàn bộ phần tử của setA, sau đó chỉ giữ lại những phần tử có ở setB
        TreeSet<Integer> intersectSet = new TreeSet<>(setA);
        intersectSet.retainAll(setB);


        // 5. In kết quả Phép Hợp (UNION)
        System.out.print("UNION:");
        for (int num : unionSet) {
            System.out.print(" " + num);
        }
        System.out.println();


        // 6. In kết quả Phép Giao (INTERSECT)
        System.out.print("INTERSECT:");
        for (int num : intersectSet) {
            System.out.print(" " + num);
        }
        System.out.println();


        sc.close();
    }
}
Đề bài: Một công ty điện lực tính tiền điện theo bậc thang như sau: 
import java.util.*;


// Xây dựng lớp HoaDon
class HoaDon {
    String maKhachHang;
    String tenKhachHang;
    int soKWh;


    // Constructor để gán dữ liệu khi khởi tạo
    public HoaDon(String maKhachHang, String tenKhachHang, int soKWh) {
        this.maKhachHang = maKhachHang;
        this.tenKhachHang = tenKhachHang;
        this.soKWh = soKWh;
    }


    // Phương thức tính tổng tiền điện lũy tiến theo bậc thang
    int tongTien() {
        int tien = 0;
        int remainingKWh = this.soKWh;


        // Bậc 1: 50 kWh đầu tiên (từ 0 đến 50)
        if (remainingKWh > 50) {
            tien += 50 * 1700;
            remainingKWh -= 50;
        } else {
            tien += remainingKWh * 1700;
            return tien;
        }


        // Bậc 2: 50 kWh tiếp theo (từ 51 đến 100)
        if (remainingKWh > 50) {
            tien += 50 * 1800;
            remainingKWh -= 50;
        } else {
            tien += remainingKWh * 1800;
            return tien;
        }


        // Bậc 3: 100 kWh tiếp theo (từ 101 đến 200)
        if (remainingKWh > 100) {
            tien += 100 * 2100;
            remainingKWh -= 100;
        } else {
            tien += remainingKWh * 2100;
            return tien;
        }


        // Bậc 4: Tất cả các kWh còn lại (lớn hơn 200)
        if (remainingKWh > 0) {
            tien += remainingKWh * 2400;
        }


        return tien;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        // Tạo danh sách để lưu các đối tượng hóa đơn nhập vào
        List<HoaDon> dsHoaDon = new ArrayList<>();
       
        for (int i = 0; i < n; i++) {
            String maKH = sc.next();
            String tenKH = sc.next();
            int soKWh = sc.nextInt();
           
            // Khởi tạo đối tượng và nạp vào danh sách
            dsHoaDon.add(new HoaDon(maKH, tenKH, soKWh));
        }
       
        long tongTatCa = 0; // Sử dụng kiểu long đề phòng tổng tiền của nhiều khách vượt quá giới hạn int
       
        // Duyệt danh sách in ra kết quả từng người và cộng dồn tổng
        for (HoaDon hd : dsHoaDon) {
