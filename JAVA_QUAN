            inputList.add(new Product(parts[0], Double.parseDouble(parts[1])));
        }


        // 1. Supplier: Cung cấp/tạo danh sách mẫu (trả về danh sách vừa nhập)
        Supplier<List<Product>> productSupplier = () -> inputList;


        // 2. Predicate: Kiểm tra điều kiện lọc sản phẩm có giá >= 100
        Predicate<Product> isExpensive = p -> p.price >= 100;


        // 3. Function: Biến đổi, chuyển tên sản phẩm thành chữ IN HOA
        // Lưu ý: Ta trả về một đối tượng Product mới để không làm thay đổi mảng gốc (immutable tư duy Stream)
        Function<Product, Product> toUppercaseName = p -> new Product(p.name.toUpperCase(), p.price);


        // 4. Comparator: Sắp xếp tăng dần theo tiêu chí giá sản phẩm
        Comparator<Product> compareByPrice = (p1, p2) -> Double.compare(p1.price, p2.price);


        // 5. Consumer: Thực thi hành động in sản phẩm ra màn hình định dạng 2 chữ số thập phân
        Consumer<Product> printProduct = p -> System.out.printf("%s %.2f\n", p.name, p.price);


        // --- Áp dụng tất cả các đối tượng Functional Interfaces trên vào Stream pipeline ---
        productSupplier.get().stream()          // Bước 1: Lấy dữ liệu từ Supplier
                .filter(isExpensive)            // Bước 2: Lọc bằng Predicate
                .map(toUppercaseName)           // Bước 3: Biến đổi bằng Function
                .sorted(compareByPrice)         // Bước 4: Sắp xếp bằng Comparator
                .forEach(printProduct);         // Bước 5: In đầu ra bằng Consumer


        sc.close();
    }
}
