Đề bài: Một thư viện cần quản lý hai loại sách: sách giấy và sách điện tử. Mỗi cuốn sách đều có: 

Bài làm 
import java.util.*;


// Định nghĩa lớp cha Book
class Book {
    String title;
    String author;
    double price;


    // Constructor cho lớp cha
    public Book(String title, String author, double price) {
        this.title = title;
        this.author = author;
        this.price = price;
    }


    double finalPrice() {
        return price;
    }
}


// Lớp con PaperBook kế thừa Book
class PaperBook extends Book {
    // Gọi constructor của lớp cha
    public PaperBook(String title, String author, double price) {
        super(title, author, price);
    }


    // Ghi đè phương thức tính giá: cộng thêm 15000đ phí vận chuyển
    @Override
    double finalPrice() {
        return price + 15000;
    }
}


// Lớp con EBook kế thừa Book
class EBook extends Book {
    // Gọi constructor của lớp cha
    public EBook(String title, String author, double price) {
        super(title, author, price);
    }


    // Ghi đè phương thức tính giá: giảm 20% (tức là còn 80% giá gốc)
    @Override
    double finalPrice() {
        return price * 0.8;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        // Sử dụng một List kiểu Book để lưu trữ đa hình tất cả các loại sách nhập vào
