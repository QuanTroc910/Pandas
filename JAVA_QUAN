                .map(codeMapper)            // Bước 3: Biến đổi dữ liệu bằng Function
                .sorted(totalDescending)    // Bước 4: Sắp xếp dữ liệu bằng Comparator
                // In kết quả đầu ra theo đúng định dạng yêu cầu (tổng tiền 2 chữ số thập phân)
                .forEach(o -> System.out.printf("%s %.2f\n", o.code, o.total));


