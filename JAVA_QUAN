import java.util.Locale;
import java.util.Scanner;


// a. Tạo lớp trừu tượng BankAccount
abstract class BankAccount {
    private String ownerName;
    protected double balance;


    // Constructor nhận đầy đủ thông tin
    public BankAccount(String ownerName, double balance) {
        this.ownerName = ownerName;
        this.balance = balance;
    }


    // Getter và Setter đầy đủ cho các thuộc tính
    public String getOwnerName() {
        return ownerName;
    }


    public void setOwnerName(String ownerName) {
        this.ownerName = ownerName;
    }


    public double getBalance() {
        return balance;
    }


    public void setBalance(double balance) {
        this.balance = balance;
    }


    // Các phương thức trừu tượng
    public abstract double calcInterest();
    public abstract void showInfo();
}


// b1. Tạo lớp SavingAccount kế thừa từ BankAccount
class SavingAccount extends BankAccount {
    private double interestRate;


    // Constructor gọi super để tái sử dụng constructor của lớp cha
    public SavingAccount(String ownerName, double balance, double interestRate) {
        super(ownerName, balance);
        this.interestRate = interestRate;
    }


    // Ghi đè phương thức tính lãi: lãi = số dư * (lãi suất / 100)
    @Override
    public double calcInterest() {
        return balance * (interestRate / 100.0);
    }


    // Ghi đè phương thức hiển thị thông tin
    @Override
    public void showInfo() {
        System.out.println("=== Tài khoản Tiết kiệm ===");
        System.out.println("Chủ tài khoản: " + getOwnerName());
        System.out.printf(Locale.US, "Số dư: %.2f\n", getBalance());
        System.out.printf(Locale.US, "Lãi: %.2f\n", calcInterest());
    }
}


// b2. Tạo lớp CheckingAccount kế thừa từ BankAccount
class CheckingAccount extends BankAccount {
    private double fee;


    // Constructor
    public CheckingAccount(String ownerName, double balance, double fee) {
        super(ownerName, balance);
        this.fee = fee;
    }


    // Tài khoản thanh toán không tính lãi -> trả về 0
    @Override
    public double calcInterest() {
        return 0.0;
    }


    // Ghi đè phương thức hiển thị thông tin kèm phí duy trì
    @Override
    public void showInfo() {
        System.out.println("=== Tài khoản Thanh toán ===");
        System.out.println("Chủ tài khoản: " + getOwnerName());
        System.out.printf(Locale.US, "Số dư: %.2f\n", getBalance());
        System.out.printf(Locale.US, "Phí duy trì: %.2f\n", fee);
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);


        // Đọc dữ liệu cho Tài khoản Tiết kiệm (SavingAccount)
        if (!sc.hasNextLine()) return;
        String name1 = sc.nextLine();
        double bal1 = sc.nextDouble();
        double rate = sc.nextDouble();
        sc.nextLine(); // Nuốt dòng trống thừa \n để không lỗi trôi lệnh ở dòng tiếp theo


        // Đọc dữ liệu cho Tài khoản Thanh toán (CheckingAccount)
        String name2 = sc.nextLine();
        double bal2 = sc.nextDouble();
        double fee = sc.nextDouble();


        // Khởi tạo các đối tượng tài khoản cụ thể
        BankAccount saving = new SavingAccount(name1, bal1, rate);
        BankAccount checking = new CheckingAccount(name2, bal2, fee);


        // Gọi phương thức đa hình hiển thị thông tin ra màn hình
        saving.showInfo();
        checking.showInfo();


        sc.close();
    }
}
Cho danh sách N sinh viên, mỗi sinh viên có lop (String), ten (String), diem (double).
Hãy sắp xếp:
lop tăng dần theo alphabet.
Cùng lớp: diem giảm dần.
Cùng lớp và điểm: ten tăng dần alphabet.
import java.util.*;


class SV {
    String lop, ten;
    double diem;
   
    SV(String l, String t, double d) {
        lop = l;
        ten = t;
        diem = d;
    }


    // Getter bổ sung hỗ trợ cấu trúc viết Method Reference gọn gàng
    public String getLop() { return lop; }
    public String getTen() { return ten; }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        // Kiểm tra an toàn đầu vào đề phòng trường hợp file test case trống
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
       
        ArrayList<SV> list = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            list.add(new SV(sc.next(), sc.next(), sc.nextDouble()));
        }


        // Tạo chuỗi so sánh đa tiêu chí theo đúng kịch bản đề bài yêu cầu
        Comparator<SV> svComparator = Comparator
                // Tiêu chí 1: Sắp xếp theo tên lớp alphabet tăng dần
                .comparing(SV::getLop)
                // Tiêu chí 2: Cùng lớp -> Sắp xếp theo điểm giảm dần (sv2 trước sv1)
                .thenComparing((sv1, sv2) -> Double.compare(sv2.diem, sv1.diem))
                // Tiêu chí 3: Cùng lớp và điểm -> Sắp xếp tên alphabet tăng dần
                .thenComparing(SV::getTen);


        // Tiến hành sắp xếp danh sách ArrayList bằng bộ Comparator vừa tạo
        list.sort(svComparator);


        // In kết quả ra màn hình (Định dạng điểm số lấy chính xác 2 chữ số thập phân)
        for (SV sv : list) {
            System.out.printf(Locale.US, "%s %s %.2f\n", sv.lop, sv.ten, sv.diem);
        }
       
        sc.close();
    }
}

