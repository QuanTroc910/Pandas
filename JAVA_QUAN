import java.io.*;
import java.util.*;
import java.util.concurrent.*;
import java.util.concurrent.atomic.AtomicLong;


public class Main {
    public static void main(String[] args) throws Exception {
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
       
        String firstLine = br.readLine();
        if (firstLine == null) return;
       
        String[] first = firstLine.split("\\s+");
        int n = Integer.parseInt(first[0]);
        int k = Integer.parseInt(first[1]);


        ExecutorService es = Executors.newFixedThreadPool(k);
        AtomicLong total = new AtomicLong(0);


        // 1. Đọc N dòng văn bản và submit từng dòng như 1 nhiệm vụ chạy song song
        for (int i = 0; i < n; i++) {
            String line = br.readLine();
           
            // Xử lý trường hợp dòng văn bản bị null (nếu có)
            if (line == null) line = "";


            final String taskLine = line;
           
            // Submit một tác vụ Runnable vào ExecutorService
            es.execute(() -> {
                String trimmed = taskLine.trim();
                if (!trimmed.isEmpty()) {
                    // Phân tách chuỗi dựa trên một hoặc nhiều khoảng trắng liên tiếp
                    String[] words = trimmed.split("\\s+");
                    int count = 0;
                    for (String word : words) {
                        if (!word.isEmpty()) {
                            count++;
                        }
                    }
                    // Cộng dồn an toàn đa luồng vào biến AtomicLong chung
                    total.addAndGet(count);
                }
            });
        }


        // 2. Ra lệnh đóng bể luồng (ngừng tiếp nhận thêm task mới)
        es.shutdown();
       
        // 3. Ép hàm main đứng đợi cho đến khi tất cả các task công việc xử lý xong xuôi hoàn toàn
        // (Thời gian chờ tối đa được cấu hình dài hạn để đảm bảo an toàn hệ thống)
        if (es.awaitTermination(1, TimeUnit.HOURS)) {
            // 4. In ra tổng số từ tìm được khi tất cả các luồng phụ đã hoàn tất nhiệm vụ
            System.out.println(total.get());
        }


        br.close();
    }
}

Cho danh sách nhân viên gồm tên và số giờ làm trong ngày. Hãy xử lý dữ liệu bằng Supplier, Predicate, Function, Comparator như sau:
Dùng Supplier để trả về danh sách nhân viên nhập vào.
import java.util.*;
import java.util.function.*;
import java.util.stream.*;


class Staff {
    String name;
    double hours;


    Staff(String name, double hours) {
        this.name = name;
        this.hours = hours;
    }
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextLine()) return;
        int N = Integer.parseInt(sc.nextLine().trim());


        List<Staff> list = new ArrayList<>();
        for (int i = 0; i < N; i++) {
            String[] p = sc.nextLine().split(" ");
            list.add(new Staff(p[0], Double.parseDouble(p[1])));
        }


        // 1. Khai báo Supplier: Trả về danh sách nhân viên đã nhập vào
        Supplier<List<Staff>> staffSupplier = () -> list;
   
        // 2. Khai báo Predicate: Lọc nhân viên có số giờ làm >= 6 giờ
        Predicate<Staff> workingHourFilter = s -> s.hours >= 6.0;
   
        // 3. Khai báo Function: Quy đổi số giờ làm thành số phút (giờ * 60)
        // Ánh xạ thành mảng Object[] chứa: [Tên, Giờ, Phút] để các bước sau dễ bóc tách
        Function<Staff, Object[]> minuteConverter = s -> new Object[]{ s.name, s.hours, (int) (s.hours * 60) };
   
        // 4. Khai báo Comparator: Sắp xếp theo số phút (nằm ở chỉ số index = 2) giảm dần
        // Truyền obj2 trước obj1 để đảo ngược thứ tự thành giảm dần
        Comparator<Object[]> minutesDescending = (obj1, obj2) -> Integer.compare((int) obj2[2], (int) obj1[2]);
   
        // --- Sử dụng các đối tượng trên xuyên suốt Stream pipeline để xử lý dữ liệu ---
        staffSupplier.get().stream()
                .filter(workingHourFilter)  // Bước 2: Lọc dữ liệu bằng Predicate
                .map(minuteConverter)       // Bước 3: Biến đổi dữ liệu bằng Function
                .sorted(minutesDescending)  // Bước 4: Sắp xếp dữ liệu bằng Comparator
                // Bước 5: In kết quả đầu ra theo đúng định dạng (Giờ hiển thị 2 chữ số thập phân)
                .forEach(obj -> System.out.printf(Locale.US, "%s %.2f %d\n", obj[0], obj[1], obj[2]));
       
        sc.close();
    }
}
Hãy viết một chương trình Java thực hiện các yêu cầu sau:
Tạo một Functional Interface tên là Operation có một phương thức trừu tượng:
int apply(int a, int b);
Trong lớp Main, sử dụng biểu thức lambda để:
Thực hiện phép cộng hai số.
Thực hiện phép trừ hai số.
Thực hiện phép nhân hai số.
Thực hiện phép chia hai số (nếu số chia là 0, in ra "Không thể chia cho 0").
Người dùng nhập vào hai số nguyên a và b, chương trình in ra kết quả của 4 phép toán trên.
import java.util.Scanner;


// Định nghĩa Functional Interface tùy biến theo yêu cầu đề bài
@FunctionalInterface
interface Operation {
    int apply(int a, int b);
}


public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);


        // Kiểm tra an toàn đầu vào đề phòng test case trống từ hệ thống OJ
        if (!sc.hasNextInt()) return;
        int a = sc.nextInt();
        int b = sc.nextInt();


        // 1. Sử dụng biểu thức Lambda để triển khai phép cộng
        Operation add = (x, y) -> x + y;


        // 2. Sử dụng biểu thức Lambda để triển khai phép trừ
        Operation sub = (x, y) -> x - y;


        // 3. Sử dụng biểu thức Lambda để triển khai phép nhân
        Operation multiply = (x, y) -> x * y;


        // 4. Sử dụng biểu thức Lambda viết khối lệnh triển khai phép chia
        Operation divide = (x, y) -> {
            if (y == 0) {
                throw new ArithmeticException("Không thể chia cho 0");
            }
            return x / y;
        };


        // In kết quả lần lượt theo đúng cấu trúc định dạng của đề bài
        System.out.println("Cộng: " + add.apply(a, b));
        System.out.println("Trừ: " + sub.apply(a, b));
        System.out.println("Nhân: " + multiply.apply(a, b));


        // Bọc phép chia trong khối try-catch để xử lý an toàn trường hợp số chia bằng 0
        try {
            System.out.println("Chia: " + divide.apply(a, b));
        } catch (ArithmeticException e) {
            System.out.println(e.getMessage());
        }


        sc.close();
    }
}
Viết chương trình Java sử dụng Functional Interface IntSupplier để sinh ra 5 số nguyên ngẫu nhiên trong khoảng từ 1 đến 100. Sau đó, in ra các số này và tính tổng của chúng. 

import java.util.function.IntSupplier;
import java.util.Random;


public class Main {
    public static void main(String[] args) {


        Random random = new Random();


        // Tạo IntSupplier sinh số ngẫu nhiên trong khoảng [1, 100] mà hệ thống cấp sẵn
        IntSupplier randomSupplier = () -> random.nextInt(100) + 1;


        int sum = 0;


        // Vòng lặp chạy đúng 5 lần để lấy ra 5 số ngẫu nhiên từ Supplier
        for (int i = 0; i < 5; i++) {
            // Kích hoạt hàm getAsInt() để bốc số ngẫu nhiên ra
            int randomNumber = randomSupplier.getAsInt();
           
            // Cộng dồn vào biến tổng
            sum += randomNumber;
           
            // In số ngẫu nhiên ra màn hình trên cùng một dòng, cách nhau một khoảng trắng
            System.out.print(randomNumber + " ");
        }


        // Dòng in tổng hệ thống đã viết sẵn ở cuối
        System.out.println("\nTổng = " + sum);
    }
}
