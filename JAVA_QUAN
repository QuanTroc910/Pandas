    // Vị trí của đoạn bị mất trong s sẽ tương ứng 1:1 với vị trí trong stringGoc
    string doanBiMat = stringGoc.substr(startIdx, length);


    // 4. In kết quả của bộ test hiện tại
    cout << doanBiMat << "\n";
}


