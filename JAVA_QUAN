Định nghĩa lớp Counter extends Thread lưu phần mảng phụ trách + biến local đếm cục bộ.
Tạo K thread, mỗi thread đếm trên phần của mình.
Gọi join() để đợi tất cả thread kết thúc.
Tổng hợp kết quả và in một số nguyên ra màn hình.
import java.util.*;


// Định nghĩa lớp Counter kế thừa từ Thread
class Counter extends Thread {
    int[] arr;
    int from;
    int to;
    int threshold;
    int local = 0; // Biến local đếm cục bộ số phần tử > X


    // Constructor để gán dữ liệu đoạn mảng phụ trách
    public Counter(int[] arr, int from, int to, int threshold) {
        this.arr = arr;
        this.from = from;
        this.to = to;
        this.threshold = threshold;
    }


    // Logic duyệt đoạn mảng và đếm các phần tử lớn hơn threshold chạy song song
    @Override
    public void run() {
        for (int i = from; i < to; i++) {
            if (arr[i] > threshold) {
                local++;
            }
        }
    }
}


public class Main {
    public static void main(String[] args) throws Exception {
        Scanner sc = new Scanner(System.in);
       
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }
        int k = sc.nextInt();
        int x = sc.nextInt();


        // Tạo mảng quản lý K thread
        Counter[] threads = new Counter[k];


        // Chia việc phân đoạn mảng đều cho K thread
        int baseSize = n / k;
        int remainder = n % k;


        int currentStart = 0;
        for (int i = 0; i < k; i++) {
            int currentEnd = currentStart + baseSize + (i < remainder ? 1 : 0);


            // Khởi tạo từng thread và truyền tham số threshold (chính là X)
            threads[i] = new Counter(arr, currentStart, currentEnd, x);
            threads[i].start(); // Kích hoạt luồng chạy song song


            currentStart = currentEnd;
        }


        int totalCount = 0;


        // Gọi join() để đợi tất cả các thread kết thúc và tổng hợp kết quả
        for (int i = 0; i < k; i++) {
            threads[i].join(); // Đợi thread i hoàn thành hoàn toàn
            totalCount += threads[i].local; // Cộng dồn kết quả đếm cục bộ vào tổng
        }


        // In tổng số nguyên kết quả ra màn hình
        System.out.println(totalCount);


        sc.close();
    }
}
